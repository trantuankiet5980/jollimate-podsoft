{% schema %}
{
  "name": "Custom Collection Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "🔥 DON'T MISS OUT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Popular Collections"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Collection Grid",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign is_popular_collection_grid = false
  if section.settings.heading == 'Popular Collections' or section.settings.heading == 'Explore Popular Collections'
    assign is_popular_collection_grid = true
  endif

  assign popular_collection_columns = 2
  assign popular_collection_max_width = '360px'
  assign popular_collection_desktop_columns = section.blocks.size
  if popular_collection_desktop_columns < 1
    assign popular_collection_desktop_columns = 1
  endif

  if section.blocks.size > 4
    assign popular_collection_columns = 3
    assign popular_collection_max_width = '560px'
  endif

  assign is_new_on_grid = false
  if section.settings.heading == 'New On Jollimate'
    assign is_new_on_grid = true
  elsif section.id == 'new_on_gossby_custom' and is_popular_collection_grid == false
    assign is_new_on_grid = true
  endif

  assign use_popular_slider = false
  if section.id == 'new_on_gossby_custom' and is_popular_collection_grid == false
    assign use_popular_slider = true
  endif
-%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');

  .custom-collection-grid-section {
    font-family: 'Poppins', sans-serif;
  }

  .epc-container {
    max-width: var(--page-width);
    margin: 0 auto;
    width: 100%;
  }

  .epc-header {
    text-align: center;
    margin-bottom: 24px;
    padding: 0;
  }

  .epc-badge {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    color: #ff523b;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .epc-heading {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 0;
    color: #333;
  }

  .epc-scroll-wrapper {
    overflow-x: auto;
    padding: 0 20px 0px 20px;
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */

    /* Improve scrolling experience */
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    display: flex;
    justify-content: flex-start;
  }

  .epc-scroll-wrapper::-webkit-scrollbar {
    display: none;
  }

  .epc-grid {
    display: flex;
    flex-wrap: nowrap;
    gap: 20px;
    width: 100%;
    padding-right: 20px;
  }

  /* Center the scroll wrapper content if it fits on large screens */
  @media (min-width: 1200px) {
    .epc-scroll-wrapper {
      justify-content: center;
    }
  }

  .epc-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    width: 270px; /* Fixed width as requested */
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .epc-item:hover {
    transform: translateY(-5px);
  }

  .epc-image-wrapper {
    width: 270px;
    height: 270px; /* Fixed height matching width */
    overflow: hidden;
    margin-bottom: 15px;
  }

  .epc-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .epc-item:hover .epc-image {
    transform: scale(1.05);
  }

  .epc-title {
    font-size: 16px;
    font-weight: 600;
    color: #333;
    text-align: center;
  }

  {% if is_new_on_grid %}
    #shopify-section-{{ section.id }} .epc-scroll-wrapper {
      justify-content: flex-start;
      overflow-x: visible;
      display: block;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .epc-grid {
      width: 100%;
      padding-right: 0;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: clamp(16px, 2vw, 28px);
    }

    #shopify-section-{{ section.id }} .epc-item {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .epc-image-wrapper {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }

    @media (max-width: 990px) {
      #shopify-section-{{ section.id }} .epc-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 749px) {
      #shopify-section-{{ section.id }} .epc-grid {
        grid-template-columns: 1fr;
      }
    }
  {% endif %}

  {% if is_popular_collection_grid %}
    #shopify-section-{{ section.id }} .epc-scroll-wrapper {
      justify-content: center;
      overflow-x: visible;
      display: block;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .epc-grid {
      width: 100%;
      max-width: 100%;
      margin: 0 auto;
      padding-right: 0;
      display: grid;
      grid-template-columns: repeat(var(--popular-collection-desktop-columns), minmax(0, 1fr));
      gap: clamp(16px, 2vw, 28px);
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .epc-item {
      width: 100%;
      min-width: 0;
      flex: none;
    }

    #shopify-section-{{ section.id }} .epc-image-wrapper {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 6px;
      margin-bottom: 8px;
    }

    #shopify-section-{{ section.id }} .epc-image {
      border-radius: 6px;
    }

    #shopify-section-{{ section.id }} .epc-title {
      font-size: 16px;
      line-height: 1.25;
      font-weight: 600;
    }

    @media (max-width: 749px) {
      #MainContent #shopify-section-{{ section.id }} .custom-collection-grid-section,
      #shopify-section-{{ section.id }} .custom-collection-grid-section {
        padding-top: 16px !important;
      }

      #shopify-section-{{ section.id }} .epc-heading {
        margin-top: 0 !important;
      }

      #shopify-section-{{ section.id }} .epc-scroll-wrapper {
        padding: 0 10px;
      }

      #shopify-section-{{ section.id }} .epc-grid {
        max-width: var(--popular-collection-max-width);
        grid-template-columns: repeat(var(--popular-collection-columns), minmax(0, 1fr));
        gap: 16px clamp(14px, 3.8vw, 18px);
      }

      #shopify-section-{{ section.id }} .epc-title {
        font-size: 14px;
      }
    }
  {% endif %}

  {% if section.settings.heading == 'Shop Our Most Popular Categories' %}
    #shopify-section-{{ section.id }} .epc-scroll-wrapper {
      justify-content: flex-start;
      overflow-x: visible;
      display: block;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .epc-grid {
      width: 100%;
      max-width: 100%;
      padding-right: 0;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: clamp(12px, 1.6vw, 22px);
    }

    #shopify-section-{{ section.id }} .epc-item {
      width: 100%;
      min-width: 0;
      flex: 1 1 calc((100% - (5 * clamp(12px, 1.6vw, 22px))) / 6);
    }

    #shopify-section-{{ section.id }} .epc-image-wrapper {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }

    @media (max-width: 1199px) {
      #shopify-section-{{ section.id }} .epc-item {
        flex: 1 1 calc((100% - (2 * clamp(12px, 1.6vw, 22px))) / 3);
      }
    }

    @media (max-width: 749px) {
      #shopify-section-{{ section.id }} .epc-item {
        flex: 1 1 calc((100% - clamp(12px, 1.6vw, 22px)) / 2);
      }
    }
  {% endif %}

  {% if section.settings.heading == 'Trending This Week' %}
    #shopify-section-{{ section.id }} .epc-scroll-wrapper {
      justify-content: flex-start;
      overflow-x: visible;
      display: block;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .epc-grid {
      width: 100%;
      max-width: 100%;
      padding-right: 0;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: clamp(12px, 1.6vw, 22px);
    }

    #shopify-section-{{ section.id }} .epc-item {
      width: 100%;
      min-width: 0;
      flex: 1 1 calc((100% - (3 * clamp(12px, 1.6vw, 22px))) / 4);
    }

    #shopify-section-{{ section.id }} .epc-image-wrapper {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }

    @media (max-width: 990px) {
      #shopify-section-{{ section.id }} .epc-item {
        flex: 1 1 calc((100% - clamp(12px, 1.6vw, 22px)) / 2);
      }
    }

    @media (max-width: 749px) {
      #shopify-section-{{ section.id }} .epc-item {
        flex: 1 1 calc((100% - clamp(12px, 1.6vw, 22px)) / 2);
      }
    }
  {% endif %}

  {% if use_popular_slider %}
    #shopify-section-{{ section.id }} .epc-scroll-shell {
      position: relative;
    }

    #shopify-section-{{ section.id }} .epc-scroll-wrapper {
      overflow-x: auto;
      overflow-y: hidden;
      padding: 0;
      display: block;
      scroll-behavior: smooth;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    #shopify-section-{{ section.id }} .epc-scroll-wrapper::-webkit-scrollbar {
      display: none;
    }

    #shopify-section-{{ section.id }} .epc-grid {
      display: flex;
      flex-wrap: nowrap;
      gap: 20px;
      width: auto;
      padding-right: 0;
      justify-content: flex-start;
    }

    #shopify-section-{{ section.id }} .epc-item {
      flex: 0 0 calc((100% - 60px) / 4);
      width: auto;
      min-width: 240px;
      scroll-snap-align: start;
    }

    #shopify-section-{{ section.id }} .epc-image-wrapper {
      width: 93%;
      height: auto;
      aspect-ratio: 1 / 1;
    }

    #shopify-section-{{ section.id }} .epc-nav-btn {
      position: absolute;
      top: 42%;
      transform: translateY(-50%);
      z-index: 6;
      width: 38px;
      height: 38px;
      border-radius: 999px;
      border: 1px solid rgba(0, 0, 0, 0.14);
      background: #fff;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #555;
      transition: all 0.2s ease;
    }

    #shopify-section-{{ section.id }} .epc-nav-btn:hover {
      background: #f5f5f5;
      box-shadow: 0 3px 12px rgba(0, 0, 0, 0.12);
    }

    #shopify-section-{{ section.id }} .epc-nav-btn[disabled] {
      opacity: 0.35;
      cursor: default;
    }

    #shopify-section-{{ section.id }} .epc-nav-btn--prev {
      left: -8px;
    }

    #shopify-section-{{ section.id }} .epc-nav-btn--next {
      right: -8px;
    }

    #shopify-section-{{ section.id }} .epc-nav-btn svg {
      width: 16px;
      height: 16px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    @media (max-width: 990px) {
      #shopify-section-{{ section.id }} .epc-item {
        flex-basis: calc((100% - 20px) / 2);
        min-width: 180px;
      }
    }

    @media (max-width: 749px) {
      #shopify-section-{{ section.id }} .epc-scroll-wrapper {
        padding: 0 8px;
      }

      #shopify-section-{{ section.id }} .epc-item {
        flex-basis: calc((100% - (0.4 * 20px)) / 1.4);
        min-width: calc((100% - (0.4 * 20px)) / 1.4);
      }

      #shopify-section-{{ section.id }} .epc-nav-btn {
        display: none;
      }
    }
  {% endif %}
</style>

<div
  class="custom-collection-grid-section"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="epc-container">
    <div class="epc-header">
      {% if section.settings.badge_text != blank %}
        <div class="epc-badge">{{ section.settings.badge_text }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="epc-heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="epc-scroll-shell">
      {% if use_popular_slider %}
        <button type="button" class="epc-nav-btn epc-nav-btn--prev" id="epcPrev-{{ section.id }}" aria-label="Previous">
          <svg viewBox="0 0 24 24">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
      {% endif %}

      <div class="epc-scroll-wrapper" id="epcScroll-{{ section.id }}">
        <div
          class="epc-grid"
          {% if is_popular_collection_grid %}
            style="--popular-collection-desktop-columns: {{ popular_collection_desktop_columns }}; --popular-collection-columns: {{ popular_collection_columns }}; --popular-collection-max-width: {{ popular_collection_max_width }};"
          {% endif %}
        >
          {% for block in section.blocks %}
            <a href="{{ block.settings.link | default: '#' }}" class="epc-item">
              <div class="epc-image-wrapper">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'epc-image' }}
                {% else %}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg epc-image' }}
                {% endif %}
              </div>
              <div class="epc-title">{{ block.settings.title }}</div>
            </a>
          {% endfor %}
        </div>
      </div>

      {% if use_popular_slider %}
        <button type="button" class="epc-nav-btn epc-nav-btn--next" id="epcNext-{{ section.id }}" aria-label="Next">
          <svg viewBox="0 0 24 24">
            <polyline points="9 6 15 12 9 18"></polyline>
          </svg>
        </button>
      {% endif %}
    </div>
  </div>
</div>

{% if use_popular_slider %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const scrollEl = document.getElementById('epcScroll-{{ section.id }}');
      const prevBtn = document.getElementById('epcPrev-{{ section.id }}');
      const nextBtn = document.getElementById('epcNext-{{ section.id }}');
      if (!scrollEl || !prevBtn || !nextBtn) return;

      const getStep = () => {
        const firstItem = scrollEl.querySelector('.epc-item');
        if (!firstItem) return 320;
        const styles = window.getComputedStyle(scrollEl.querySelector('.epc-grid'));
        const gap = parseFloat(styles.columnGap || styles.gap || 20) || 20;
        return firstItem.getBoundingClientRect().width + gap;
      };

      const updateButtons = () => {
        const hasOverflow = scrollEl.scrollWidth - scrollEl.clientWidth > 2;
        if (!hasOverflow) {
          prevBtn.style.display = 'none';
          nextBtn.style.display = 'none';
        } else {
          prevBtn.style.display = 'flex';
          nextBtn.style.display = 'flex';
          prevBtn.disabled = false;
          nextBtn.disabled = false;
        }
      };

      const scrollLoop = (direction) => {
        const step = getStep();
        const maxScroll = scrollEl.scrollWidth - scrollEl.clientWidth;
        if (maxScroll <= 2) return;

        if (direction === 'next') {
          if (scrollEl.scrollLeft >= maxScroll - 2) {
            scrollEl.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            scrollEl.scrollBy({ left: step, behavior: 'smooth' });
          }
          return;
        }

        if (scrollEl.scrollLeft <= 2) {
          scrollEl.scrollTo({ left: maxScroll, behavior: 'smooth' });
        } else {
          scrollEl.scrollBy({ left: -step, behavior: 'smooth' });
        }
      };

      prevBtn.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        scrollLoop('prev');
      });

      nextBtn.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        scrollLoop('next');
      });

      scrollEl.addEventListener('scroll', updateButtons, { passive: true });
      window.addEventListener('resize', updateButtons);
      updateButtons();
    });
  </script>
{% endif %}
