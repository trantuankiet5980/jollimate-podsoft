<section
  id="MainProduct-{{ section.id }}"
  class="page-width section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
>
  {% comment %}
    {%- if section.settings.show_breadcrumbs -%}
      <div class="product-breadcrumbs page-width">
        {% render 'breadcrumbs' %}
      </div>
    {%- endif -%}
  {% endcomment %}

  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    /* Item Details & Shipping Refund Accordion Custom Styling */
    .item-details-accordion,
    .shipping-refund-accordion {
      border: none !important;
      border-bottom: 1px solid rgba(var(--color-foreground), 0.08) !important;
    }

    .item-details-accordion summary,
    .shipping-refund-accordion summary {
      list-style: none !important;
      border: none !important;
      padding: 1rem 0 !important;
    }

    .item-details-accordion summary::-webkit-details-marker,
    .shipping-refund-accordion summary::-webkit-details-marker {
      display: none !important;
    }

    .item-details-accordion .summary__title,
    .shipping-refund-accordion .summary__title {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .item-details-accordion .accordion__title,
    .shipping-refund-accordion .accordion__title {
      margin: 0;
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--color-foreground);
    }

    .item-details-accordion summary .icon-caret,
    .shipping-refund-accordion summary .icon-caret {
      transition: transform 0.3s ease;
    }

    .item-details-accordion[open] summary .icon-caret,
    .shipping-refund-accordion[open] summary .icon-caret {
      transform: rotate(180deg);
    }

    .item-details-accordion .accordion__content,
    .shipping-refund-accordion .accordion__content {
      padding: 0 0 1.5rem 0 !important;
    }

    .item-details-accordion .accordion__content rte {
      font-size: 1.5rem;
      line-height: 1.6;
      color: var(--color-foreground);
    }

    /* Delivery Estimate Compact Mobile Styles */
    .delivery-estimate-hover-area {
       transition: opacity 0.2s ease;
    }
    
    #dynamic-delivery-date:hover {
       opacity: 0.8;
       cursor: pointer;
    }

    #dynamic-delivery-date {
      border-bottom: 1.5px dashed #111;
      padding-bottom: 1px;
      color: #111;
      font-weight: 700;
      font-style: normal;
    }

    .static-delivery-estimate {
      display: none !important;
    }

    .delivery-estimate-lite-timeline {
      position: relative;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      padding-top: 10px;
    }

    .delivery-estimate-lite-timeline::before {
      content: '';
      position: absolute;
      top: 27px;
      left: 15%;
      right: 15%;
      height: 2px;
      background: #2f9d5b;
      opacity: 0.75;
      border-radius: 999px;
    }

    .delivery-estimate-lite-card {
      margin: 18px 0;
      padding: 15px 14px 16px;
      border: 1px solid #e4e9e5;
      border-radius: 8px;
      background: #fbfcfb;
    }

    .delivery-estimate-lite-heading {
      display: inline-block;
      margin-bottom: 12px;
      border-bottom: 1px dashed #8b8b8b;
      color: #111;
      font-size: 14px;
      font-weight: 600;
      line-height: 1.45;
    }

    .delivery-estimate-lite-step {
      position: relative;
      z-index: 1;
      display: grid;
      justify-items: center;
      gap: 6px;
      min-width: 0;
      font-size: 13px;
      line-height: 1.35;
      text-align: center;
    }

    .delivery-estimate-lite-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border: 1px solid #b9dec4;
      border-radius: 999px;
      background: #eff8f2;
      color: #1f7a3f;
    }

    .delivery-estimate-lite-icon svg {
      width: 17px;
      height: 17px;
    }

    .delivery-estimate-lite-step span {
      color: #666;
      font-size: 12px;
      font-weight: 500;
    }

    .delivery-estimate-lite-step strong {
      color: #111;
      font-size: 13px;
      font-weight: 700;
      line-height: 1.25;
    }

    @media screen and (max-width: 360px) {
      .delivery-estimate-lite-card {
        padding-left: 10px;
        padding-right: 10px;
      }

      .delivery-estimate-lite-step span,
      .delivery-estimate-lite-step strong {
        font-size: 11px;
      }
    }
    
    @media screen and (max-width: 749px) {
      .static-delivery-estimate {
        margin-top: 4px !important;
        padding-bottom: 5px !important;
        font-size: 1.3rem !important;
      }
      .static-delivery-estimate .flag-container {
        margin-bottom: 4px !important;
        gap: 6px !important;
      }
      .static-delivery-estimate img {
        width: 18px !important;
        height: 12px !important;
      }
      .delivery-estimate-hover-area {
        gap: 6px !important;
        font-size: 1.3rem !important;
      }
      .delivery-estimate-hover-area svg {
        width: 18px !important;
        height: 18px !important;
      }
      .delivery-estimate-text-prefix {
        display: inline;
      }
    }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer" type="module"></script>
  {%- liquid
    assign is_teeinblue_product = false
    if product.tags contains 'teeinblue-campaign' or product.tags contains 'teeinblue' or product.type == 'Customizer' or product.type == 'teeinblue' or product.vendor == 'teeinblue'
      assign is_teeinblue_product = true
    endif
  -%}
  {%- if is_teeinblue_product -%}
    <script src="{{ 'tee-sticky-gallery.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  {% if section.settings.image_zoom == 'hover' %}
    <script id="EnableZoomOnHover-main" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}

  <div class="product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col {% if product.media.size > 0 %}grid--2-col-tablet{% else %}product--no-media{% endif %}">
    <div class="grid__item product__media-wrapper product__column-sticky{% if section.settings.media_position == 'right' %} medium-hide large-up-hide{% endif %}">
      {% render 'product-media-gallery', variant_images: variant_images %}
    </div>
    <div class="product__info-wrapper grid__item{% if settings.page_width > 1400 and section.settings.media_size == "small" %} product__info-wrapper--extra-padding{% endif %}">
      <product-info
        id="ProductInfo-{{ section.id }}"
        data-section="{{ section.id }}"
        data-url="{{ product.url }}"
        class="product__info-container{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
      >
        {%- assign product_form_id = 'product-form-' | append: section.id -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {%- assign block_id_lower = block.id | downcase -%}
              {%- unless block_id_lower contains 'essential' -%}
                {% render block %}
              {%- endunless -%}
            {%- when 'text' -%}
              {%- unless product.tags contains 'teeinblue' or product.tags contains 'teeinblue-campaign' or product.type == 'Customizer' or product.vendor == 'teeinblue' -%}
                <p
                  class="product__text inline-richtext{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </p>
              {%- endunless -%}
            {%- when 'title' -%}
              <div class="product__title" {{ block.shopify_attributes }}>
                <h1>{{ product.title | escape }}</h1>
                <a href="{{ product.url }}" class="product__title">
                  <h2 class="h1">
                    {{ product.title | escape }}
                  </h2>
                </a>
              </div>
            {%- when 'custom_price' -%}
              <div class="product-custom-price" {{ block.shopify_attributes }}>
                <!-- Custom Price Container -->
                <div id="custom-price-display" class="custom-price-style">
                  <!-- Fallback Static Price (Liquid) -->
                  <div class="custom-price-loading">
                    {%- render 'price',
                      product: product,
                      use_variant: true,
                      show_badges: false,
                      price_class: 'price--large'
                    -%}
                  </div>

                  <!-- Dynamic Price (Filled by JS) -->
                  <div class="custom-price-content" style="display:none;">
                    <span class="custom-compare-price" style="display:none;"><!-- $29.99 --></span>
                    <span class="custom-current-price"><!-- $14.99 --></span>
                    <span class="custom-saving-badge" style="display:none;"><!-- saving $6.00 --></span>
                  </div>
                </div>

                <style>
                  .custom-price-style .price-item {
                    color: #e53935;
                    font-weight: 700;
                    font-size: 2rem;
                  } /* Fallback style */

                  #custom-price-display .price__sale .price-item--regular,
                  #custom-price-display .custom-compare-price,
                  #custom-price-display .custom-saving-badge {
                    display: none !important;
                  }

                  .custom-price-content {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    flex-wrap: wrap;
                  }
                  .custom-compare-price {
                    text-decoration: line-through;
                    color: #888;
                    font-size: 1.6rem;
                  }
                  .custom-from-label {
                    color: #888;
                    font-size: 1.4rem;
                  }

                  .custom-current-price {
                    color: #e53935;
                    font-weight: 700;
                    font-size: 2rem;
                  }
                  .custom-saving-badge {
                    background-color: #F97B22;
                    color: #fff;
                    padding: 4px 12px;
                    border-radius: 20px;
                    font-size: 1.2rem;
                    font-weight: bold;
                    line-height: 1.2;
                  }
                </style>

                <script>
                  document.addEventListener('DOMContentLoaded', function () {
                    const displayContainer = document.querySelector('#custom-price-display .custom-price-content');
                    const currentPriceEl = displayContainer.querySelector('.custom-current-price');
                    const comparePriceEl = displayContainer.querySelector('.custom-compare-price');
                    const loadingContainer = document.querySelector('#custom-price-display .custom-price-loading');
                    const savingBadgeEl = displayContainer.querySelector('.custom-saving-badge');

                    // Helper to parse price string to number
                    // Handles both USD ("962.50") and VND ("962.000") formats
                    function parsePrice(priceText) {
                      if (!priceText) return 0;
                      let cleaned = priceText.replace(/[^\d.,]/g, '').trim();
                      const lastDot = cleaned.lastIndexOf('.');
                      const lastComma = cleaned.lastIndexOf(',');
                      if (lastComma > lastDot) {
                        // Comma is decimal sep (e.g. European: "1.962,50")
                        cleaned = cleaned.replace(/\./g, '').replace(',', '.');
                      } else if (lastDot > -1) {
                        const afterDot = cleaned.substring(lastDot + 1);
                        if (afterDot.length === 3) {
                          // Dot is thousands sep (e.g. VND: "962.000")
                          cleaned = cleaned.replace(/\./g, '').replace(/,/g, '');
                        } else {
                          // Dot is decimal sep (e.g. USD: "962.50")
                          cleaned = cleaned.replace(/,/g, '');
                        }
                      }
                      return parseFloat(cleaned) || 0;
                    }

                    // Helper to format currency using the shop's active currency
                    function formatCurrency(amount) {
                      try {
                        const currency =
                          window.Shopify && window.Shopify.currency && window.Shopify.currency.active
                            ? window.Shopify.currency.active
                            : 'USD';
                        return new Intl.NumberFormat(undefined, {
                          style: 'currency',
                          currency: currency,
                          minimumFractionDigits: 0,
                          maximumFractionDigits: 0,
                        }).format(amount);
                      } catch (e) {
                        return amount.toFixed(0);
                      }
                    }

                    // --- 1. PRICE SYNC LOGIC ---
                    let isSyncingPrice = false;
                    const nativePriceContainer = document.getElementById('price-{{ section.id }}');

                    function applyPriceToCustomDisplay(currentPriceText, comparePriceText) {
                      const normalizedCurrent = (currentPriceText || '').trim();
                      const normalizedCompare = (comparePriceText || '').trim();
                      if (!normalizedCurrent) return false;

                      isSyncingPrice = true;

                      if (currentPriceEl && currentPriceEl.innerText !== normalizedCurrent) {
                        currentPriceEl.innerText = normalizedCurrent;
                      }

                      if (loadingContainer && loadingContainer.style.display !== 'none') {
                        loadingContainer.style.display = 'none';
                        displayContainer.style.display = 'flex';
                      }

                      if (normalizedCompare !== '' && comparePriceEl) {
                        if (comparePriceEl.innerText !== normalizedCompare) {
                          comparePriceEl.innerText = normalizedCompare;
                        }
                        if (comparePriceEl.style.display !== 'inline') {
                          comparePriceEl.style.display = 'inline';
                        }

                        const currentVal = parsePrice(normalizedCurrent);
                        const compareVal = parsePrice(normalizedCompare);
                        const savingVal = compareVal - currentVal;

                        if (savingVal > 0 && savingBadgeEl) {
                          const newBadgeText = 'saving ' + formatCurrency(savingVal);
                          if (savingBadgeEl.innerText !== newBadgeText) {
                            savingBadgeEl.innerText = newBadgeText;
                          }
                          if (savingBadgeEl.style.display !== 'inline-block') {
                            savingBadgeEl.style.display = 'inline-block';
                          }
                        } else if (savingBadgeEl && savingBadgeEl.style.display !== 'none') {
                          savingBadgeEl.style.display = 'none';
                        }
                      } else {
                        if (comparePriceEl && comparePriceEl.style.display !== 'none') {
                          comparePriceEl.style.display = 'none';
                        }
                        if (savingBadgeEl && savingBadgeEl.style.display !== 'none') {
                          savingBadgeEl.style.display = 'none';
                        }
                      }

                      setTimeout(() => {
                        isSyncingPrice = false;
                      }, 50);

                      return true;
                    }

                    function getNativeShopifyPrice() {
                      if (!nativePriceContainer) return null;
                      const salePriceEl = nativePriceContainer.querySelector('.price-item--sale');
                      const saleCompareEl = nativePriceContainer.querySelector('.price__sale .price-item--regular');
                      const regularPriceEl = nativePriceContainer.querySelector('.price__regular .price-item--regular');

                      const current = (salePriceEl?.textContent || regularPriceEl?.textContent || '').trim();
                      const compare = salePriceEl ? (saleCompareEl?.textContent || '').trim() : '';

                      if (!current) return null;
                      return { current, compare };
                    }

                    function formatVariantMoney(cents) {
                      const value = (Number(cents) || 0) / 100;
                      const currency =
                        (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) || 'USD';
                      try {
                        const symbolParts = new Intl.NumberFormat(undefined, {
                          style: 'currency',
                          currency,
                          currencyDisplay: 'narrowSymbol',
                          minimumFractionDigits: 2,
                          maximumFractionDigits: 2,
                        }).formatToParts(value);
                        const currencySymbol = symbolParts.find((part) => part.type === 'currency')?.value || '$';

                        const amountText = new Intl.NumberFormat(undefined, {
                          minimumFractionDigits: 2,
                          maximumFractionDigits: 2,
                        }).format(value);
                        return currencySymbol + amountText + ' ' + currency;
                      } catch (e) {
                        return '$' + value.toFixed(2) + ' ' + currency;
                      }
                    }

                    function syncFromVariantObject(variant) {
                      if (!variant || typeof variant.price === 'undefined') return false;
                      const currentText = formatVariantMoney(variant.price);
                      const compareText =
                        variant.compare_at_price && Number(variant.compare_at_price) > Number(variant.price)
                          ? formatVariantMoney(variant.compare_at_price)
                          : '';
                      return applyPriceToCustomDisplay(currentText, compareText);
                    }

                    function syncFromSelectedVariant() {
                      const variantPicker =
                        document.querySelector('variant-radios[data-section="{{ section.id }}"]') ||
                        document.querySelector('variant-selects[data-section="{{ section.id }}"]');
                      if (!variantPicker) return false;

                      const variantJson = variantPicker.querySelector('script[type="application/json"]');
                      if (!variantJson) return false;

                      let variants = [];
                      try {
                        variants = JSON.parse(variantJson.textContent || '[]');
                      } catch (e) {
                        return false;
                      }

                      let options = [];
                      if (variantPicker.tagName.toLowerCase() === 'variant-radios') {
                        const fieldsets = Array.from(variantPicker.querySelectorAll('fieldset'));
                        options = fieldsets
                          .map((fieldset) => fieldset.querySelector('input:checked')?.value)
                          .filter(Boolean);
                      } else {
                        options = Array.from(variantPicker.querySelectorAll('select')).map((select) => select.value);
                      }

                      if (!options.length) return false;

                      const matched = variants.find((variant) => {
                        if (!variant || !variant.options || variant.options.length !== options.length) return false;
                        return variant.options.every((option, index) => option === options[index]);
                      });

                      return syncFromVariantObject(matched);
                    }

                    function checkAndSyncPrice() {
                      if (isSyncingPrice) return;

                      const teePriceBlock = document.querySelector('.tee-block.tee-product-price');
                      if (teePriceBlock) {
                        const currentPriceText =
                          teePriceBlock.querySelector('.tee-price--current')?.innerText ||
                          teePriceBlock.querySelector('.teeinblue-price-text')?.innerText;

                        if (currentPriceText) {
                          const compareOne = teePriceBlock.querySelector('.tee-price--compare');
                          const comparePriceText = (compareOne?.innerText || '').trim();
                          applyPriceToCustomDisplay(currentPriceText, comparePriceText);
                          return;
                        }
                      }

                      const nativePrice = getNativeShopifyPrice();
                      if (nativePrice) {
                        applyPriceToCustomDisplay(nativePrice.current, nativePrice.compare);
                      }
                    }

                    // Run price sync once on load
                    checkAndSyncPrice();

                    // Observe DOM changes to catch Teeinblue variant price updates dynamically
                    const debouncedSyncPrice = (typeof debounce === 'function') 
                      ? debounce(checkAndSyncPrice, 150) 
                      : () => {
                          clearTimeout(window._priceSyncTimer);
                          window._priceSyncTimer = setTimeout(checkAndSyncPrice, 150);
                        };

                    const priceObserver = new MutationObserver(debouncedSyncPrice);

                    // Observe the product info container instead of the entire body for better performance
                    const priceObservationTarget = document.querySelector('.product__info-container') || document.body;
                    priceObserver.observe(priceObservationTarget, {
                      childList: true,
                      subtree: true,
                      characterData: true,
                    });

                    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
                      subscribe(PUB_SUB_EVENTS.variantChange, function (event) {
                        const variant = event && event.data ? event.data.variant : null;
                        if (!syncFromVariantObject(variant)) {
                          setTimeout(checkAndSyncPrice, 0);
                        }
                      });
                    }

                    const variantPickerEl =
                      document.querySelector('variant-radios[data-section="{{ section.id }}"]') ||
                      document.querySelector('variant-selects[data-section="{{ section.id }}"]');
                    if (variantPickerEl) {
                      variantPickerEl.addEventListener('change', function () {
                        setTimeout(() => {
                          if (!syncFromSelectedVariant()) {
                            checkAndSyncPrice();
                          }
                        }, 0);
                      });
                    }

                    // === FETCH INTERCEPTOR → Show detailed cart popup ===
                    if (!window.__cartPopupInterceptor) {
                      window.__cartPopupInterceptor = true;

                      function isAddToCartUrl(url, method) {
                        try {
                          method = (method || 'GET').toUpperCase();
                          return (
                            typeof url === 'string' &&
                            method === 'POST' &&
                            (url.includes('/cart/add.js') || url.includes('/cart/add')) &&
                            !url.includes('hot-reload')
                          );
                        } catch (e) {
                          return false;
                        }
                      }

                      const originalFetch = window.fetch;
                      window.fetch = function (...args) {
                        const url = args[0];
                        const opts = args[1] || {};
                        const promise = originalFetch.apply(this, args);
                        if (isAddToCartUrl(url, opts.method)) {
                          promise.then((response) => {
                            if (response.ok) {
                              response
                                .clone()
                                .json()
                                .then((data) => {
                                  // Show popup if we have real item data
                                  if (data && (data.product_title || data.title)) {
                                    setTimeout(() => showCartPopup(data), 500);
                                  }
                                  // Refresh cart badge count
                                  fetch('/cart.js')
                                    .then((res) => res.json())
                                    .then((cart) => {
                                      document
                                        .querySelectorAll('.cart-count-bubble span[aria-hidden="true"]')
                                        .forEach((badge) => {
                                          badge.textContent = cart.item_count > 999 ? '999+' : cart.item_count;
                                        });
                                      document.querySelectorAll('.cart-count-bubble').forEach((bubble) => {
                                        bubble.style.display = cart.item_count > 0 ? '' : 'none';
                                      });
                                      const customBadge = document.querySelector('.custom-top-bar__cart-count');
                                      if (customBadge)
                                        customBadge.textContent = cart.item_count > 999 ? '999+' : cart.item_count;
                                    })
                                    .catch(() => {});
                                  // Refresh cart drawer content silently (no open)
                                  originalFetch('/?sections=cart-drawer,cart-icon-bubble')
                                    .then((res) => res.json())
                                    .then((sections) => {
                                      if (sections['cart-drawer']) {
                                        const drawerEl = document.getElementById('CartDrawer');
                                        if (drawerEl) {
                                          const parsed = new DOMParser().parseFromString(
                                            sections['cart-drawer'],
                                            'text/html'
                                          );
                                          const newDrawer = parsed.querySelector('#CartDrawer');
                                          if (newDrawer) {
                                            drawerEl.innerHTML = newDrawer.innerHTML;
                                            const overlayEl = drawerEl.querySelector('#CartDrawer-Overlay');
                                            const cartDrawerComponent = document.querySelector('cart-drawer');
                                            if (overlayEl && cartDrawerComponent) {
                                              overlayEl.addEventListener(
                                                'click',
                                                cartDrawerComponent.close.bind(cartDrawerComponent)
                                              );
                                            }
                                            if (
                                              cartDrawerComponent &&
                                              cartDrawerComponent.classList.contains('is-empty')
                                            ) {
                                              cartDrawerComponent.classList.remove('is-empty');
                                            }
                                          }
                                        }
                                      }
                                    })
                                    .catch(() => {});
                                })
                                .catch(() => {});
                            }
                            return response;
                          });
                        }
                        return promise;
                      };
                    }

                    // === CART SUCCESS POPUP (detailed with product info) ===
                    if (!document.getElementById('cart-popup-styles')) {
                      const popupStyle = document.createElement('style');
                      popupStyle.id = 'cart-popup-styles';
                      popupStyle.textContent = `
                        .cart-popup-overlay {
                          position: fixed; inset: 0; z-index: 99999;
                          background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);
                          display: flex; align-items: center; justify-content: center;
                          opacity: 0; transition: opacity 0.4s cubic-bezier(0.16,1,0.3,1); padding: 16px;
                        }
                        .cart-popup-overlay.show { opacity: 1; }
                        .cart-popup {
                          background: #fff; border-radius: 20px; max-width: 440px; width: 100%;
                          box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
                          transform: translateY(20px); transition: transform 0.5s cubic-bezier(0.34,1.56,0.64,1);
                          overflow: hidden; font-family: inherit;
                        }
                        .cart-popup-overlay.show .cart-popup { transform: translateY(0); }
                        .cart-popup__header {
                          display: flex; align-items: center; gap: 10px;
                          padding: 16px 20px; border-bottom: 1px solid #f1f5f9; position: relative;
                        }
                        .cart-popup__header-icon { width: 20px; height: 20px; color: #10b981; }
                        .cart-popup__header-text { font-size: 14px; font-weight: 600; color: #059669; margin: 0; flex: 1; }
                        .cart-popup__close { background: none; border: none; color: #94a3b8; cursor: pointer; padding: 4px; display: flex; }
                        .cart-popup__content { padding: 24px 20px; display: flex; gap: 16px; }
                        .cart-popup__img-wrap { width: 100px; height: 100px; background: #f8fafc; border-radius: 8px; overflow: hidden; flex-shrink: 0; }
                        .cart-popup__img-wrap img { width: 100%; height: 100%; object-fit: cover; }
                        .cart-popup__info { flex: 1; min-width: 0; }
                        .cart-popup__prod-title { font-size: 15px; font-weight: 600; color: #0f172a; margin: 0 0 6px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
                        .cart-popup__prod-meta { font-size: 13px; color: #64748b; margin-bottom: 4px; }
                        .cart-popup__prod-meta span { color: #0f172a; font-weight: 500; }
                        .cart-popup__prod-price { font-size: 16px; font-weight: 700; color: #F97B22; margin-top: 8px; }
                        .cart-popup__actions { padding: 0 20px 24px; display: flex; flex-direction: column; gap: 12px; }
                        .cart-popup__btn { display: flex; align-items: center; justify-content: center; width: 100%; padding: 14px; border-radius: 12px; font-size: 15px; font-weight: 700; cursor: pointer; transition: all 0.2s ease; text-decoration: none; }
                        .cart-popup__btn-view { background: #F97B22; color: #fff; border: none; }
                        .cart-popup__btn-view:hover { background: #b52424; }
                        .cart-popup__btn-continue { background: #fff; color: #F97B22; border: 2px solid #F97B22; }
                        .cart-popup__btn-continue:hover { background: #fff5f6; }
                        @media (max-width: 749px) {
                          .cart-popup-overlay { align-items: flex-end; padding: 0; }
                          .cart-popup { max-width: 100%; border-radius: 20px 20px 0 0; transform: translateY(100%); transition: transform 0.45s cubic-bezier(0.32,0.72,0,1); }
                          .cart-popup-overlay.show .cart-popup { transform: translateY(0); }
                        }
                      `;
                      document.head.appendChild(popupStyle);
                    }

                    window.showCartPopup =
                      window.showCartPopup ||
                      function showCartPopup(item) {
                        document.querySelectorAll('.cart-popup-overlay').forEach((el) => el.remove());
                        if (!item || !(item.product_title || item.title)) return;

                        const overlay = document.createElement('div');
                        overlay.className = 'cart-popup-overlay';

                        const currency =
                          (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) || 'USD';
                        // Use currencyDisplay:'code' so it shows "USD 79.99" instead of "US$79.99"
                        const priceNumber = new Intl.NumberFormat(undefined, {
                          style: 'decimal',
                          minimumFractionDigits: 2,
                          maximumFractionDigits: 2,
                        }).format(item.price / 100);
                        const price = currency + ' ' + priceNumber;
                        let optionsHtml = '';
                        if (item.options_with_values) {
                          optionsHtml = item.options_with_values
                            .map(
                              (opt) => `<div class="cart-popup__prod-meta">${opt.name}: <span>${opt.value}</span></div>`
                            )
                            .join('');
                        }

                        overlay.innerHTML = `
                        <div class="cart-popup">
                          <div class="cart-popup__header">
                            <div class="cart-popup__header-icon">
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            </div>
                            <h4 class="cart-popup__header-text">Item added to your cart!</h4>
                            <button class="cart-popup__close" aria-label="Close">
                              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                            </button>
                          </div>
                          <div class="cart-popup__content">
                            <!-- Image removed per user request -->
                            <div class="cart-popup__info">
                              <h5 class="cart-popup__prod-title">${item.product_title || item.title}</h5>
                              ${optionsHtml}
                              <div class="cart-popup__prod-meta">Quantity: <span>${item.quantity || 1}</span></div>
                              <div class="cart-popup__prod-price">${price}</div>
                            </div>
                          </div>
                          <div class="cart-popup__actions">
                            <button type="button" class="cart-popup__btn cart-popup__btn-continue">Continue Shopping</button>
                            <a href="/cart" class="cart-popup__btn cart-popup__btn-view">View Cart & Checkout</a>
                          </div>
                        </div>
                      `;
                        document.body.appendChild(overlay);
                        requestAnimationFrame(() => requestAnimationFrame(() => overlay.classList.add('show')));

                        const close = () => {
                          overlay.classList.remove('show');
                          setTimeout(() => overlay.remove(), 400);
                        };
                        overlay.addEventListener('click', (e) => {
                          if (e.target === overlay) close();
                        });
                        overlay.querySelector('.cart-popup__btn-continue').addEventListener('click', close);
                        overlay.querySelector('.cart-popup__close')?.addEventListener('click', close);
                        setTimeout(() => {
                          if (overlay.parentNode) close();
                        }, 6000);
                      };
                  });
                </script>
                {%- liquid
