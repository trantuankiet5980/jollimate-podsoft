                <!-- JS: Gallery popup and Custom Delivery Modal -->
                <script>
                  document.addEventListener('DOMContentLoaded', function() {
                    // === TEEINBLUE GALLERY POPUP: Click outside overlay to close ===
                    function setupGalleryOverlayClose() {
                      document.addEventListener('click', function(e) {
                        var overlay = e.target.closest('.vm--overlay');
                        if (overlay) {
                          var container = overlay.closest('.vm--container') || overlay.parentElement;
                          if (container) {
                            var closeBtn = container.querySelector('.tee-dialog-close') ||
                                           container.querySelector('[title="Close"]') ||
                                           container.querySelector('.vm--modal .tee-dialog-close');
                            if (closeBtn) closeBtn.click();
                            else {
                              container.style.display = 'none';
                              document.body.style.overflow = '';
                            }
                          }
                        }
                      });
                    }
                    setupGalleryOverlayClose();

                    // === MOBILE DELIVERY ESTIMATE: Scroll to Shipping Accordion ===
                    // === DELIVERY ESTIMATE: Scroll to Shipping Accordion when Date is clicked ===
                    var targetDateArea = document.getElementById('dynamic-delivery-date');
                    if (targetDateArea) {
                      targetDateArea.addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        
                        var accordion = null;
                        var sections = document.querySelectorAll('.product__accordion details, details');
                        for (var i = 0; i < sections.length; i++) {
                          var summary = sections[i].querySelector('summary');
                          if (summary && summary.textContent.toLowerCase().indexOf('shipping') !== -1) {
                            accordion = sections[i];
                            break;
                          }
                        }
                        
                        if (accordion) {
                          accordion.setAttribute('open', 'true');
                          
                          const stickyGallery = document.querySelector('.tee-gallery-content');
                          const isSticky = document.body.classList.contains('gallery--sticky');
                          const stickyHeight = (isSticky && stickyGallery) ? stickyGallery.offsetHeight : (document.querySelector('sticky-header') ? document.querySelector('sticky-header').offsetHeight : 60);
                          
                          const viewportHeight = window.innerHeight;
                          const visibleHeight = viewportHeight - stickyHeight;
                          const targetRect = accordion.getBoundingClientRect();
                          const targetTop = targetRect.top + window.pageYOffset;
                          const targetHeight = targetRect.height;
                          
                          let offset = (visibleHeight - targetHeight) / 2;
                          if (offset < 20) offset = 20;

                          const finalPosition = targetTop - stickyHeight - offset;
                          
                          window.scrollTo({
                            top: finalPosition,
                            behavior: 'smooth'
                          });
                        }
                      });
                    }
                  });
                </script>
