                  </script>

                  <div
                    class="delivery-estimate-hover-area"
                    style="display: flex; align-items: center; gap: 10px; width: fit-content; cursor: help; position: relative;"
                  >
                    <svg
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="#333"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                      <line x1="4" y1="7" x2="12" y2="7"></line>
                      <line x1="4" y1="11" x2="12" y2="11"></line>
                    </svg>
                    <span
                      ><span class="delivery-estimate-text-prefix">Order today and </span>get it by:
                      <strong
                        id="dynamic-delivery-date"
                        data-min-days="{{ delivery_min_days }}"
                        data-max-days="{{ delivery_max_days }}"
                        >calculating...</strong
                      ></span
                    >

                    <script>
                      (function () {
                        const targetDateSpan = document.getElementById('dynamic-delivery-date');
                        if (!targetDateSpan) return;

                        const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                        let minDays = parseInt(targetDateSpan.dataset.minDays || '8', 10);
                        let maxDays = parseInt(targetDateSpan.dataset.maxDays || '13', 10);
                        const processingMinDays = 2;
                        const processingMaxDays = 3;

                        if (!isFinite(minDays) || minDays < 1) minDays = 8;
                        if (!isFinite(maxDays) || maxDays < minDays) maxDays = Math.max(minDays, 13);

                        const addDays = function (days) {
                          const date = new Date();
                          date.setHours(12, 0, 0, 0);
                          date.setDate(date.getDate() + days);
                          return date;
                        };

                        const formatDate = function (date) {
                          return monthNames[date.getMonth()] + ' ' + date.getDate();
                        };

                        const formatRange = function (startDate, endDate) {
                          if (startDate.getMonth() === endDate.getMonth()) {
                            return monthNames[startDate.getMonth()] + ' ' + startDate.getDate() + ' - ' + endDate.getDate();
                          }
                          return formatDate(startDate) + ' - ' + formatDate(endDate);
                        };

                        const orderDate = addDays(0);
                        const shipStart = addDays(processingMinDays);
                        const shipEnd = addDays(processingMaxDays);
                        const deliveryStart = addDays(minDays);
                        const deliveryEnd = addDays(maxDays);
                        const dates = {
                          order: formatDate(orderDate),
                          ship: formatRange(shipStart, shipEnd),
                          delivered: formatRange(deliveryStart, deliveryEnd)
                        };

                        const writeText = function (selector, text) {
                          document.querySelectorAll(selector).forEach(function (element) {
                            element.textContent = text;
                          });
                        };

                        const populateDeliveryDates = function () {
                          targetDateSpan.textContent = dates.delivered;
                          writeText('[data-delivery-order-date]', dates.order);
                          writeText('[data-delivery-ship-date]', dates.ship);
                          writeText('[data-delivery-delivered-date]', dates.delivered);
                        };

                        populateDeliveryDates();
                        if (document.readyState === 'loading') {
                          document.addEventListener('DOMContentLoaded', populateDeliveryDates, { once: true });
                        }
                      })();
                    </script>

                    <div class="delivery-estimate-popover" id="delivery-estimate-dynamic-popover">
