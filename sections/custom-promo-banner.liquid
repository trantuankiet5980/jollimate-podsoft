{% schema %}
{
  "name": "Custom Promo Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f9eccb"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Positive Crochet Collection"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover unique handmade gifts for your loved ones."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Promo Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Custom Promo Banner"
    }
  ]
}
{% endschema %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&display=swap');

  .custom-promo-banner {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column-reverse; /* Mobile: Image on top or bottom? Usually image top. Let's do standard stack */
    align-items: center;
    padding: 30px 20px;
    text-align: center;
  }

  .cpb-content {
    flex: 1;
    z-index: 2;
    padding: 20px;
    width: 100%;
  }

  .cpb-heading {
    font-family: 'Fredoka One', cursive;
    font-size: 28px; /* Mobile size */
    color: #d34e4e; /* Reddish color from image */
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .cpb-subheading {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #555;
    margin-bottom: 20px;
  }

  .cpb-button {
    background-color: #d34e4e;
    color: #fff;
    padding: 10px 24px;
    border-radius: 25px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    display: inline-block;
    transition: background 0.3s;
  }

  .cpb-button:hover {
    background-color: #b03a3a;
  }

  .cpb-image-wrapper {
    flex: 1;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .cpb-image {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    max-height: 250px;
  }

  /* Desktop */
  @media (min-width: 768px) {
    .custom-promo-banner {
      flex-direction: row;
      text-align: left;
      padding: 40px 60px;
      justify-content: space-between;
    }

    .cpb-content {
      align-items: flex-start;
      text-align: left;
      padding-right: 40px;
    }

    .cpb-heading {
      font-size: 36px;
    }

    .cpb-subheading {
      font-size: 16px;
    }

    .cpb-image-wrapper {
      justify-content: flex-end;
    }

    .cpb-image {
      max-height: 350px;
    }
  }
</style>

<div
  class="page-width"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="custom-promo-banner" style="background-color: {{ section.settings.background_color }};">
    <div class="cpb-content">
      {% if section.settings.heading != blank %}
        <h2 class="cpb-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="cpb-subheading">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="cpb-button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="cpb-image-wrapper">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'cpb-image' }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg cpb-image' }}
      {% endif %}
    </div>
  </div>
</div>
