{% comment %} Trending Searches Section {% endcomment %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

  .ts-section-{{ section.id }} {
    font-family: 'Poppins', sans-serif;
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .ts-container-{{ section.id }} {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 20px;
    width: 100%;
    box-sizing: border-box;
  }

  .ts-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 24px;
  }

  .ts-heading-{{ section.id }} {
    font-size: 28px;
    font-weight: 700;
    color: #333;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .ts-tags-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .ts-tag-{{ section.id }} {
    display: inline-block;
    padding: 6px 16px;
    border: 2px solid #333;
    border-radius: 12px;
    font-size: 16px;
    line-height: 1.3;
    font-weight: 500;
    color: #333;
    text-decoration: none;
    background-color: #fff;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .ts-tag-{{ section.id }}:hover {
    background-color: #f97b22;
    color: #fff;
    border-color: #f97b22;
  }

  @media (max-width: 749px) {
    .ts-heading-{{ section.id }} { font-size: 28px; }
    .ts-tag-{{ section.id }} {
      font-size: 16px;
      padding: 6px 16px;
    }
  }
</style>

<div class="ts-section-{{ section.id }}">
  <div class="ts-container-{{ section.id }}">
    {%- if section.settings.heading != blank -%}
      <div class="ts-header-{{ section.id }}">
        <h2 class="ts-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="ts-tags-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.settings.label != blank -%}
          {%- liquid
            if block.settings.link != blank
              assign tag_url = block.settings.link
            else
              assign tag_url = block.settings.label | url_encode | prepend: '/search?q='
            endif
          -%}
          <a
            href="{{ tag_url }}"
            class="ts-tag-{{ section.id }}"
            {{ block.shopify_attributes }}
          >{{ block.settings.label }}</a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trending Searches",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending Searches Now"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "search_tag",
      "name": "Search Tag",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "easter gifts"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trending Searches",
      "blocks": [
        { "type": "search_tag", "settings": { "label": "easter gifts" } },
        { "type": "search_tag", "settings": { "label": "graduation gifts" } },
        { "type": "search_tag", "settings": { "label": "mother's day" } },
        { "type": "search_tag", "settings": { "label": "travel" } },
        { "type": "search_tag", "settings": { "label": "gift for mom" } },
        { "type": "search_tag", "settings": { "label": "memorial gifts" } },
        { "type": "search_tag", "settings": { "label": "america's 250th" } },
        { "type": "search_tag", "settings": { "label": "anniversary gifts" } }
      ]
    }
  ]
}
{% endschema %}
