{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

  .fcf-section {
    font-family: 'Poppins', sans-serif;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .collection-badge {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    color: #ff523b;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .fc-heading {
    font-size: 28px !important;
    font-weight: 700 !important;
    color: #333;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-align: center;
  }

  /* Filter Pills */
  .fcf-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin: 24px 0 32px;
    list-style: none;
    padding: 0;
  }

  .fcf-filter-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 6px 16px;
    min-height: 0;
    background: #fff;
    border: 2px solid #333;
    border-radius: 12px;
    font-size: 16px;
    line-height: 1.3;
    font-weight: 500;
    color: #333;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
    text-align: center;
    font-family: 'Poppins', sans-serif;
  }

  .fcf-filter-item:hover {
    background-color: #f97b22;
    color: #fff;
    border-color: #f97b22;
  }

  .fcf-filter-item.active {
    background-color: #f97b22;
    border-color: #f97b22;
    color: #fff;
  }

  @media screen and (max-width: 749px) {
    .fc-heading {
      font-size: 28px !important;
    }

    .fcf-filter-item {
      font-size: 16px;
      padding: 6px 16px;
      min-height: 0;
    }
  }

  /* Loading State */
  .fcf-grid-container {
    position: relative;
    transition: opacity 0.3s ease;
  }

  .fcf-grid-container.loading {
    opacity: 0.5;
    pointer-events: none;
  }

  .fcf-loader {
    display: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
  }

  .fcf-grid-container.loading .fcf-loader {
    display: block;
  }

  .fc-view-all-btn {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 12px 32px;
    background: #F48525;
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 50px;
    margin-top: 24px;
    transition: opacity 0.3s ease;
  }

  .fc-view-all-btn:hover {
    opacity: 0.9;
    color: #fff;
  }
{%- endstyle -%}

{%- liquid
  # Determine current collection to show
  assign current_collection = section.settings.collection
  
  # For AJAX requests, we use the collection being accessed
  if request.path contains '/collections/'
    assign path_parts = request.path | split: '/'
    assign handle = path_parts[2]
    assign current_collection = collections[handle]
  endif

  assign products_to_display = current_collection.all_products_count
  assign view_all_url = current_collection.url

  if current_collection.all_products_count > section.settings.products_to_show
    assign products_to_display = section.settings.products_to_show
    assign more_in_collection = true
  endif

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and products_to_display > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and products_to_display > section.settings.columns_desktop
    assign show_desktop_slider = true
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient fcf-section" id="fcf-section-{{ section.id }}">
  <div class="collection section-{{ section.id }}-padding{% if section.settings.full_width %} collection--full-width{% endif %}">
    <div
      class="collection__title title-wrapper title-wrapper--no-top-margin page-width"
      style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%;"
    >
      {%- if section.settings.badge_text != blank -%}
        <div class="collection-badge">{{ section.settings.badge_text }}</div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="title inline-richtext fc-heading">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}

      <!-- Filter Badges -->
      {%- if section.blocks.size > 0 -%}
        <ul class="fcf-filters">
          <li class="fcf-filter-item active" data-url="{{ section.settings.collection.url }}">All</li>
          {%- for block in section.blocks -%}
            {%- if block.settings.collection != blank -%}
              <li class="fcf-filter-item" data-url="{{ block.settings.collection.url }}" {{ block.shopify_attributes }}>
                {{ block.settings.label | default: block.settings.collection.title | escape }}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="fcf-grid-container" id="fcf-grid-{{ section.id }}">
      <div class="fcf-loader">
        <svg  width="40" height="40" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="25" cy="25" r="20" stroke="#F48525" stroke-width="4" stroke-dasharray="31.415, 31.415" stroke-linecap="round">
            <animateTransform attributeName="transform" type="rotate" from="0 25 25" to="360 25 25" dur="1s" repeatCount="indefinite" />
          </circle>
        </svg>
      </div>

      <div id="fcf-inner-{{ section.id }}">
        <slider-component class="slider-mobile-gutter{% if section.settings.full_width %} slider-component-full-width{% endif %}{% if show_mobile_slider == false %} page-width{% endif %}{% if show_desktop_slider == false and section.settings.full_width == false %} page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}">
          <ul
            id="Slider-{{ section.id }}"
            class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop{% if current_collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
            role="list"
          >
            {%- for product in current_collection.products limit: section.settings.products_to_show -%}
              <li
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}"
              >
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  show_quick_add: section.settings.enable_quick_add,
                  section_id: section.id
                %}
              </li>
            {%- else -%}
              {%- for i in (1..section.settings.products_to_show) -%}
                <li class="grid__item">
                  {% render 'card-product', show_vendor: section.settings.show_vendor, media_aspect_ratio: section.settings.image_ratio %}
                </li>
              {%- endfor -%}
            {%- endfor -%}
          </ul>
        </slider-component>

        {%- if section.settings.show_view_all and more_in_collection -%}
          <div class="center collection__view-all">
            <a
              href="{{ view_all_url }}"
              class="fc-view-all-btn"
            >
              View All Products
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const sectionId = '{{ section.id }}';
    const container = document.getElementById(`fcf-section-${sectionId}`);
    if (!container) return;

    const filters = container.querySelectorAll('.fcf-filter-item');
    const gridContainer = document.getElementById(`fcf-grid-${sectionId}`);
    const innerContainer = document.getElementById(`fcf-inner-${sectionId}`);

    filters.forEach(filter => {
      filter.addEventListener('click', function () {
        if (this.classList.contains('active')) return;

        // Update UI
        filters.forEach(f => f.classList.remove('active'));
        this.classList.add('active');

        const baseUrl = this.dataset.url;
        if (!baseUrl) return;

        // Shopify section rendering API
        const url = new URL(baseUrl, window.location.origin);
        url.searchParams.set('section_id', sectionId);

        // Show loading
        gridContainer.classList.add('loading');

        fetch(url.toString())
          .then(response => response.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newInner = doc.getElementById(`fcf-inner-${sectionId}`);

            if (newInner) {
              innerContainer.innerHTML = newInner.innerHTML;
            }
          })
          .catch(e => console.error('Filter error:', e))
          .finally(() => {
            gridContainer.classList.remove('loading');
          });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Filterable Featured Coll",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "🔥 DON'T MISS OUT"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Trending This Week",
      "label": "Title"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Default Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 10,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 5,
      "label": "Columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show View All"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "Enable desktop slider",
      "default": false
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "background-1", "label": "Background 1" }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Product Cards"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adapt" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "square",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "Show secondary image"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": true,
      "label": "Show rating"
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "default": false,
      "label": "Enable quick add"
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "Swipe on mobile"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "collection_filter",
      "name": "Collection Filter",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Filterable Featured Coll"
    }
  ]
}
{% endschema %}
