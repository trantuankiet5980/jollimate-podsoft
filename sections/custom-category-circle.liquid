{% schema %}
{
  "name": "Category Circle List",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Category Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Circle List",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}

<div
  class="page-width"
  {% comment %} style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;" {% endcomment %}
  style="padding-top: 36px; padding-bottom: 0px;"
>
  {% if section.settings.heading != blank %}
    <h2 class="h2" style="text-align: center; margin-bottom: 20px;">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="category-circle-wrapper" style="position: relative; max-width: 100%; margin: 0 auto;">
    <button class="slider-arrow slider-arrow--prev" aria-label="Previous">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>

    <div class="category-circle-list" id="CategoryCircleList-{{ section.id }}">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="category-circle-item" ondragstart="return false;">
          <div class="category-circle-image-wrapper">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag: loading: 'lazy', class: 'category-circle-img', draggable: false
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg category-circle-img' }}
            {% endif %}
          </div>
          <span class="category-circle-text">{{ block.settings.title }}</span>
        </a>
      {% endfor %}
    </div>

    <button class="slider-arrow slider-arrow--next" aria-label="Next">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&display=swap');
  .category-circle-list {
    display: flex;
    flex-wrap: nowrap; /* Never wrap, horizontal scroll */
    overflow-x: auto;
    justify-content: flex-start; /* Start aligns when scrolling */
    gap: 10px;
    width: fit-content; /* Allow centering if small */
    max-width: 100%; /* But constrain to parent */
    margin: 0 auto; /* Center it */
    padding-bottom: 20px;

    /* Hide Scrollbar */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .category-circle-list::-webkit-scrollbar {
    display: none;
  }

  .category-circle-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    width: 280px; /* Increased size */
    text-align: center;
    transition: transform 0.2s;
    flex-shrink: 0; /* Prevent shrinking */
  }

  .category-circle-item:hover {
    transform: translateY(-5px);
  }

  .category-circle-image-wrapper {
    width: 220px; /* Increased size */
    height: 220px; /* Increased size */
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: 12px;
    border: 2px solid transparent;
    transition: border-color 0.3s;
    background-color: #fceceb; /* Soft pink bg like reference */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .category-circle-item:hover .category-circle-image-wrapper {
    border-color: #000;
  }

  .category-circle-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .category-circle-text {
    font-family: 'Fredoka One', cursive; /* Use Fredoka One */
    font-size: 15px;
    font-weight: bold; /* Bold */
    color: #111;
    line-height: 1.2;
    letter-spacing: 0.5px;
  }

  .placeholder-svg {
    width: 100%;
    height: 100%;
    fill: #ccc;
  }

  /* Mobile Responsive Styles */
  @media screen and (max-width: 750px) {
    .category-circle-list {
      justify-content: flex-start;
      margin: 0 -1.5rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .category-circle-item {
      width: 30vw; /* Approx 3 items (~33%) a bit smaller to show part of 4th or spacing */
      min-width: 120px;
      margin-right: 20px;
      flex-shrink: 0;
    }

    .category-circle-image-wrapper {
      width: 140px; /* Reduce size on mobile */
      height: 140px;
    }

    .category-circle-text {
      font-size: 14px;
    }
  }

  /* Slider Arrow Styles */
  .slider-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px; /* Size of button */
    height: 40px;
    border-radius: 50%;
    background-color: #fff;
    border: 1px solid #ddd;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: all 0.2s ease;
    opacity: 0; /* Hidden by default, shown via JS or hover if desired */
    pointer-events: none;
  }

  .category-circle-wrapper:hover .slider-arrow {
    opacity: 1;
    pointer-events: auto;
  }

  .slider-arrow:hover {
    background-color: #f7f7f7;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
  }

  .slider-arrow--prev {
    left: 10px;
  }

  .slider-arrow--next {
    right: 10px;
  }

  /* Grab Cursor for Drag */
  .category-circle-list {
    cursor: grab;
    user-select: none; /* Prevent text selection while dragging */
  }

  .category-circle-list.active {
    cursor: grabbing;
    cursor: -webkit-grabbing;
    scroll-behavior: auto !important; /* Critical for smooth drag */
  }

  .slider-arrow.slider-arrow--hidden {
    display: none !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const list = document.getElementById('CategoryCircleList-{{ section.id }}');
    const wrapper = list.closest('.category-circle-wrapper');
    const prevBtn = wrapper.querySelector('.slider-arrow--prev');
    const nextBtn = wrapper.querySelector('.slider-arrow--next');

    let isDown = false;
    let startX;
    let scrollLeft;
    let wasDragging = false;

    // Drag to scroll
    list.addEventListener('mousedown', (e) => {
      isDown = true;
      wasDragging = false; // Reset drag status
      list.classList.add('active');
      startX = e.pageX - list.offsetLeft;
      scrollLeft = list.scrollLeft;
    });

    list.addEventListener('mouseleave', () => {
      isDown = false;
      list.classList.remove('active');
    });

    list.addEventListener('mouseup', () => {
      isDown = false;
      list.classList.remove('active');
    });

    list.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - list.offsetLeft;
      const walk = (x - startX) * 1.5; // Scroll speed
      list.scrollLeft = scrollLeft - walk;

      // If moved more than 5 pixels, consider it a drag
      if (Math.abs(x - startX) > 5) {
        wasDragging = true;
      }
    });

    // Prevent link click if dragged
    const links = list.querySelectorAll('.category-circle-item');
    links.forEach((link) => {
      link.addEventListener('click', (e) => {
        if (wasDragging) {
          e.preventDefault();
          e.stopPropagation();
        }
      });
    });

    // Arrow navigation
    prevBtn.addEventListener('click', () => {
      list.scrollBy({ left: -300, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      list.scrollBy({ left: 300, behavior: 'smooth' });
    });

    // Check for visibility of arrows
    const checkArrows = () => {
      // Small buffer to account for rounding errors
      const isScrollable = list.scrollWidth > list.clientWidth + 1;

      if (!isScrollable) {
        prevBtn.classList.add('slider-arrow--hidden');
        nextBtn.classList.add('slider-arrow--hidden');
      } else {
        prevBtn.classList.remove('slider-arrow--hidden');
        nextBtn.classList.remove('slider-arrow--hidden');
      }
    };

    // Initial check
    checkArrows();

    // Check on resize
    window.addEventListener('resize', checkArrows);
  });
</script>
