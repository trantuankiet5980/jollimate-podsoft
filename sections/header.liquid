                  </div>

                  {%- comment -%} Generate Sub-levels {%- endcomment -%}
                  {%- for link in section.settings.menu.links -%}
                    {%- if link.links != blank -%}
                      <div
                        class="menu-level is-next"
                        data-level-id="{{ link.handle }}"
                        data-parent-id="root"
                        data-title="{{ link.title }}"
                      >
                        {%- for childlink in link.links -%}
                          {%- if childlink.links == blank -%}
                            <a href="{{ childlink.url }}" class="menu-item">
                              <span class="menu-item__title">{{ childlink.title }}</span>
                            </a>
                          {%- else -%}
                            <div class="menu-section-header">
                              <span class="menu-item__title">{{ childlink.title }}</span>
                            </div>
                            {%- for grandchildlink in childlink.links -%}
                              <a href="{{ grandchildlink.url }}" class="menu-item menu-item--grandchild">
                                <span class="menu-item__title">{{ grandchildlink.title }}</span>
                              </a>
                            {%- endfor -%}
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                <script>
                  (function () {
                    class MobileMenu {
                      constructor() {
                        this.container = document.getElementById('MobileMenuContainer');
                        this.stack = ['root'];
                        this.backBtn = document.getElementById('MobileMenuBack');
                        this.closeBtn = document.getElementById('MobileMenuClose');
                        this.titleEl = document.getElementById('MobileMenuTitle');
                        this.levels = Array.from(this.container.querySelectorAll('.menu-level'));

                        this.init();
                      }

                      init() {
                        this.container.addEventListener('click', (e) => {
                          const trigger = e.target.closest('[data-menu-trigger]');
                          if (trigger) {
                            e.preventDefault();
                            this.push(trigger.dataset.menuTrigger);
                          }
                        });

                        this.backBtn.addEventListener('click', (e) => {
                          e.stopImmediatePropagation();
                          this.pop();
                        });
                        this.closeBtn.addEventListener('click', (e) => {
                          e.stopImmediatePropagation();
                          this.handleClose();
                        });

                        // Reset when drawer closes
                        const details = this.container.closest('details');
                        if (details) {
                          details.addEventListener('toggle', () => {
                            if (!details.open) {
                              // Small delay to allow closing animation to finish
                              setTimeout(() => this.reset(), 400);
                            }
                          });
                        }
                      }

                      reset() {
                        this.levels.forEach((level) => {
                          level.classList.remove('is-active', 'is-prev');
                          level.classList.add('is-next');
                          if (level.dataset.levelId === 'root') {
                            level.classList.remove('is-next');
                            level.classList.add('is-active');
                          }
                        });
                        this.stack = ['root'];
                        this.updateHeader();
                      }

                      push(levelId) {
                        const nextLevel = this.levels.find((l) => l.dataset.levelId === levelId);
                        const currentLevel = this.levels.find(
                          (l) => l.dataset.levelId === this.stack[this.stack.length - 1]
                        );

                        if (!nextLevel) return;

                        currentLevel.classList.remove('is-active');
                        currentLevel.classList.add('is-prev');

                        nextLevel.classList.remove('is-next');
                        nextLevel.classList.add('is-active');

                        this.stack.push(levelId);
                        this.updateHeader();
                      }

                      pop() {
                        if (this.stack.length <= 1) return;

                        const currentLevelId = this.stack.pop();
                        const prevLevelId = this.stack[this.stack.length - 1];

                        const currentLevel = this.levels.find((l) => l.dataset.levelId === currentLevelId);
                        const prevLevel = this.levels.find((l) => l.dataset.levelId === prevLevelId);

                        currentLevel.classList.remove('is-active');
                        currentLevel.classList.add('is-next');

                        prevLevel.classList.remove('is-prev');
                        prevLevel.classList.add('is-active');

                        this.updateHeader();
                      }

                      handleClose() {
                        if (this.stack.length > 1) {
                          this.pop();
                        } else {
                          // Close the whole drawer
                          const details = this.container.closest('details');
                          if (details) details.removeAttribute('open');
                        }
                      }

                      updateHeader() {
                        const currentLevelId = this.stack[this.stack.length - 1];
                        const currentLevel = this.levels.find((l) => l.dataset.levelId === currentLevelId);

                        // Update Title
                        this.titleEl.textContent = currentLevel.dataset.title || 'Menu';

                        // Show/Hide Back Button
                        if (this.stack.length > 1) {
                          this.backBtn.classList.remove('is-hidden');
                        } else {
                          this.backBtn.classList.add('is-hidden');
                        }
                      }
                    }

                    document.addEventListener('DOMContentLoaded', () => {
                      window.mobileMenu = new MobileMenu();
                    });
                  })();
                </script>
              </div>
            </div>
          </details>
        </header-drawer>
      </div>

