                    aria-label="Close menu"
                  >
                    <svg
                      viewBox="0 0 24 24"
                      width="24"
                      height="24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </div>
                </div>

                <div class="menu-navigation-container">
                  <div class="menu-level is-active" data-level-id="root">
                    {%- comment -%} Root Level: Categories Grid (as seen in screenshot) {%- endcomment -%}
                    <div class="menu-grid">
                      {%- for link in section.settings.menu.links -%}
                        <a
                          href="{{ link.url }}"
                          class="menu-grid-item"
                          data-handle="{{ link.handle }}"
                          {% if link.links != blank %}
