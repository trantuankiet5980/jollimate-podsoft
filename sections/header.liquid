                          {% endif %}
                        >
                          {%- liquid
                            assign icon_svg = 'icon-menu-' | append: link.handle | append: '.svg' | asset_url
                            assign icon_png = 'icon-menu-' | append: link.handle | append: '.png' | asset_img_url: '120x'

                          -%}
