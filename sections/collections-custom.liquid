{% schema %}
{
  "name": "Collections Custom",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "color",
      "id": "circle_bg_color",
      "label": "Circle Background Color (Fallback)",
      "default": "#f5e6f0"
    },
    {
      "type": "color_background",
      "id": "bg_gradient",
      "label": "Circle Background Gradient",
      "info": "If left empty, the fallback color above will be used."
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections Custom",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
{% endschema %}

<style>
  .cc-section {
    font-family: 'Poppins', sans-serif;
  }

  .cc-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 16px;
    width: 100%;
  }

  .cc-heading {
    text-align: center;
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 24px;
    color: #333;
  }

  /* Scroll wrapper with nav arrows */
  .cc-scroll-wrap {
    position: relative;
  }

  .cc-swiper {
    width: 100%;
    padding: 10px 0;
    overflow: hidden;
  }

  /* Navigation arrows */
  .cc-nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-60%);
    z-index: 5;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: #ffffff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #555;
    padding: 0;
  }

  .cc-nav-btn:hover {
    background: #f5f5f5;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.12);
  }

  .cc-nav-btn.swiper-button-disabled,
  .cc-nav-btn.swiper-button-lock {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .cc-nav-btn--prev {
    left: -6px;
  }

  .cc-nav-btn--next {
    right: -6px;
  }

  .cc-nav-btn svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Each circular item */
  .cc-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    width: auto; /* Let Swiper handle auto-width based on child */
  }

  .cc-item:hover {
    transform: translateY(-4px);
  }

  .cc-circle {
    width: clamp(140px, 14vw, 200px);
    height: clamp(140px, 14vw, 200px);
    border-radius: 50%;
    background: {{ section.settings.bg_gradient | default: section.settings.circle_bg_color | default: '#f5e6f0' }};
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 12px;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .cc-item:hover .cc-circle {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transform: scale(1.05);
  }

  .cc-circle img {
    width: 80%;
    height: 80%;
    object-fit: contain;
    display: block;
    transition: transform 0.3s ease;
  }

  .cc-item:hover .cc-circle img {
    transform: scale(1.1);
  }

  .cc-title {
    font-size: 15px;
    font-weight: 600;
    color: #111;
    text-align: center;
    white-space: nowrap;
  }

  /* Desktop */
  @media (min-width: 1200px) {
    .cc-nav-btn--prev {
      left: -18px;
    }
    .cc-nav-btn--next {
      right: -18px;
    }
  }

  /* Tablet */
  @media (max-width: 990px) {
    .cc-circle {
      width: 140px;
      height: 140px;
    }
  }

  /* Mobile */
  @media (max-width: 749px) {
    #MainContent #shopify-section-{{ section.id }} .cc-section,
    #shopify-section-{{ section.id }} .cc-section {
      padding-bottom: 0 !important;
    }

    .cc-heading {
      font-size: 22px;
      margin-bottom: 16px;
    }
    .cc-swiper {
      padding: 8px 0 0;
    }
    .cc-circle {
      width: clamp(90px, 28vw, 108px);
      height: clamp(90px, 28vw, 108px);
      margin-bottom: 10px;
    }
    .cc-circle img {
      width: 84%;
      height: 84%;
    }
    .cc-title {
      font-size: 14px;
      line-height: 1.3;
      white-space: normal;
    }
    .cc-nav-btn {
      display: flex;
      width: 30px;
      height: 30px;
      top: clamp(54px, 16vw, 62px);
      border-radius: 8px;
      transform: translateY(-50%);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    }
    .cc-nav-btn--prev {
      left: -15px;
    }
    .cc-nav-btn--next {
      right: -15px;
    }
    .cc-nav-btn svg {
      width: 24px;
      height: 24px;
      stroke-width: 2.75;
    }
  }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" media="print" onload="this.media='all'"/>
<noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"></noscript>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<div
  class="cc-section"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="cc-container">
    {% if section.settings.heading != blank %}
      <h2 class="cc-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="cc-scroll-wrap" id="ccScrollWrap-{{ section.id }}">
      <!-- Prev Arrow -->
      <button class="cc-nav-btn cc-nav-btn--prev" id="ccPrev-{{ section.id }}" aria-label="Scroll left">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>

      <div class="cc-swiper" id="ccSwiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide cc-item" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: center;">
                <div class="cc-circle">
                  {% if block.settings.image != blank %}
                    {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'cc-image' }}
                  {% else %}
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg cc-image' }}
                  {% endif %}
                </div>
                <span class="cc-title">{{ block.settings.title }}</span>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>

      <!-- Next Arrow -->
      <button class="cc-nav-btn cc-nav-btn--next" id="ccNext-{{ section.id }}" aria-label="Scroll right">
        <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"></polyline></svg>
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const swiperContainer = document.getElementById('ccSwiper-{{ section.id }}');
    if (!swiperContainer) return;

    // Check if Swiper is loaded before initializing
    const initSwiper = () => {
      if (typeof Swiper !== 'undefined') {
        new Swiper(swiperContainer, {
          slidesPerView: 3,
          slidesPerGroup: 1,
          spaceBetween: 8,
          loop: false,
          grabCursor: true,
          watchOverflow: true,
          navigation: {
            nextEl: '#ccNext-{{ section.id }}',
            prevEl: '#ccPrev-{{ section.id }}',
          },
          breakpoints: {
            390: { slidesPerView: 3, spaceBetween: 8 },
            750: { 
              slidesPerView: 5, 
              spaceBetween: 24
            },
            1200: { 
              slidesPerView: 6, 
              spaceBetween: 32
            }
          }
        });
      } else {
        setTimeout(initSwiper, 100);
      }
    };
    initSwiper();
  });
</script>
