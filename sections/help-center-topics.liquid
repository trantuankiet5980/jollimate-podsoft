{%- if section.settings.show_section -%}
  {%- style -%}
    .help-center-topics {
      background-color: #f9f9f9;
      padding: 6rem 0;
      text-align: center;
    }

    .help-center-topics__title {
      font-size: 3.2rem;
      margin-bottom: 4rem;
      font-weight: 300;
      color: #333;
    }

    .help-center-topics__grid {
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 2rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .help-center-topics__item {
      background: white;
      border: 1px solid #eee;
      padding: 4rem 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none;
      color: #333;
      transition: transform 0.2s;
    }

    .help-center-topics__item:hover {
      transform: translateY(-5px);
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .help-center-topics__icon-wrapper {
      width: 120px;
      height: 120px;
      background-color: #fff1f0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 2rem;
      color: #F97B22;
    }

    .help-center-topics__icon-wrapper svg {
      width: 60px;
      height: 60px;
    }

    .help-center-topics__item-title {
      font-size: 1.6rem;
      font-weight: 400;
    }

    .help-center-footer {
      padding: 2rem 0;
      border-top: 1px solid #eee;
      display: flex;
      justify-content: space-between;
      font-size: 1.2rem;
      color: #999;
      margin-top: 4rem;
    }

    .help-center-footer a {
      color: #F97B22;
      text-decoration: none;
    }

    @media screen and (max-width: 749px) {
      .help-center-topics__grid {
        grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
        padding: 0 2rem;
      }
    }
  {%- endstyle -%}

  <div class="help-center-topics">
    <div class="page-width">
      <h2 class="help-center-topics__title">{{ section.settings.title }}</h2>

      <div class="help-center-topics__grid">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.url }}" class="help-center-topics__item">
            <div class="help-center-topics__icon-wrapper">
              {%- if block.settings.icon_svg != blank -%}
                {{ block.settings.icon_svg }}
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                </svg>
              {%- endif -%}
            </div>
            <span class="help-center-topics__item-title">{{ block.settings.title }}</span>
          </a>
        {%- endfor -%}
      </div>

      <div class="help-center-footer">
        <div>{{ section.settings.footer_left_text }}</div>
        <a href="#">Back to top</a>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Help Center Topics",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Help Topics"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on Mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "text",
      "id": "footer_left_text",
      "label": "Footer Left Text",
      "default": "Jollimate Help Center"
    }
  ],
  "blocks": [
    {
      "type": "topic",
      "name": "Topic",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Topic Title"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Topic URL"
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        }
      ]
    }
  ]
}
{% endschema %}
