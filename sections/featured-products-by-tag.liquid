{%- liquid
  assign source_collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
-%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');

  .fbt-section {
    font-family: 'Poppins', sans-serif;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .fbt-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 16px;
    box-sizing: border-box;
  }

  .fbt-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .fbt-badge {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    color: #f97b22;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .fbt-heading {
    font-size: 28px;
    font-weight: 700;
    color: #333;
    margin: 0;
  }

  .fbt-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
  }

  .fbt-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }

  .fbt-card-image-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 8px;
    background: #f5f5f5;
    margin-bottom: 10px;
    position: relative;
  }

  .fbt-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .fbt-card:hover .fbt-card-image {
    transform: scale(1.05);
  }

  .fbt-card-title {
    font-size: 13px;
    font-weight: 500;
    color: #333;
    margin-bottom: 4px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .fbt-card-price {
    font-size: 14px;
    font-weight: 600;
    color: #f97b22;
  }

  .fbt-card-original-price {
    font-size: 12px;
    color: #999;
    text-decoration: line-through;
    margin-left: 4px;
    font-weight: 400;
  }

  .fbt-card-rating {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #f97b22;
    margin-bottom: 4px;
  }

  .fbt-view-all {
    text-align: center;
    margin-top: 32px;
  }

  .fbt-view-all-btn {
    display: inline-block;
    border: 1.5px solid #333;
    color: #333;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 32px;
    border-radius: 6px;
    transition: all 0.2s ease;
    font-family: 'Poppins', sans-serif;
  }

  .fbt-view-all-btn:hover {
    background: #333;
    color: #fff;
  }

  @media (max-width: 990px) {
    .fbt-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 749px) {
    .fbt-heading { font-size: 20px; }
    .fbt-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }
</style>

<div class="fbt-section">
  <div class="fbt-container">
    <div class="fbt-header">
      {%- if section.settings.badge_text != blank -%}
        <div class="fbt-badge">{{ section.settings.badge_text }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="fbt-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="fbt-grid">
      {%- for product in source_collection.products limit: products_to_show -%}
        <a href="{{ product.url }}" class="fbt-card">
          <div class="fbt-card-image-wrap">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'fbt-card-image', alt: product.title }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg fbt-card-image' }}
            {%- endif -%}
          </div>
          {%- if section.settings.show_rating and product.metafields.reviews.rating.value != blank -%}
            <div class="fbt-card-rating">
              ★ {{ product.metafields.reviews.rating.value | round: 1 }}
              <span style="color:#999;">({{ product.metafields.reviews.rating_count.value }})</span>
            </div>
          {%- endif -%}
          <div class="fbt-card-title">{{ product.title }}</div>
          <div>
            <span class="fbt-card-price">{{ product.price | money }}</span>
            {%- if product.compare_at_price > product.price -%}
              <span class="fbt-card-original-price">{{ product.compare_at_price | money }}</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.show_view_all and section.settings.view_all_link != blank -%}
      <div class="fbt-view-all">
        <a href="{{ section.settings.view_all_link }}" class="fbt-view-all-btn">View All</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Products By Collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "🔥 HOT PICKS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hot Right Now"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Max Products to Show",
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All Button",
      "default": true
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Featured Products By Collection"
    }
  ]
}
{% endschema %}
