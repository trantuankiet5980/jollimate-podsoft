<section class="shopping-for-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: {{ section.settings.background_color }};">
  <div class="shopping-for-inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="shopping-for-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="shopping-for-tags">
      {%- for block in section.blocks -%}
        {%- if block.settings.label != blank -%}
          <a
            href="{{ block.settings.link | default: '#' }}"
            class="shopping-for-tag"
            {{ block.shopify_attributes }}
          >
            {{- block.settings.label -}}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

  .shopping-for-section {
    width: 100%;
    text-align: center;
    font-family: 'Poppins', sans-serif;
  }

  .shopping-for-inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  .shopping-for-heading {
    font-size: 28px;
    font-weight: 700;
    color: #333;
    margin-bottom: 24px;
    letter-spacing: -0.01em;
  }

  .shopping-for-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .shopping-for-tag {
    display: inline-block;
    padding: 6px 16px;
    border: 2px solid #333;
    border-radius: 12px;
    font-size: 16px;
    line-height: 1.3;
    font-weight: 500;
    color: #333;
    text-decoration: none;
    background-color: #fff;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
    font-family: 'Poppins', sans-serif;
  }

  .shopping-for-tag:hover {
    background-color: #f97b22;
    color: #fff;
    border-color: #f97b22;
  }

  @media (max-width: 749px) {
    .shopping-for-heading {
      font-size: 28px;
    }

    .shopping-for-tag {
      font-size: 16px;
      padding: 6px 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Shopping For",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Who Are You Shopping For Today?"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "tag_item",
      "name": "Tag Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Mom"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shopping For",
      "blocks": [
        { "type": "tag_item", "settings": { "label": "Mom" } },
        { "type": "tag_item", "settings": { "label": "Kid & Baby" } },
        { "type": "tag_item", "settings": { "label": "For Her" } },
        { "type": "tag_item", "settings": { "label": "For Him" } },
        { "type": "tag_item", "settings": { "label": "Couple" } },
        { "type": "tag_item", "settings": { "label": "Friends" } },
        { "type": "tag_item", "settings": { "label": "Family" } },
        { "type": "tag_item", "settings": { "label": "Pet Lovers" } },
        { "type": "tag_item", "settings": { "label": "Coworkers" } }
      ]
    }
  ]
}
{% endschema %}
