<div
  class="ccp-section"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {%- if section.settings.show_breadcrumb -%}
      <nav class="ccp-breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}" class="ccp-breadcrumb__link">{{ section.settings.breadcrumb_home | escape }}</a>
        <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
        <span class="ccp-breadcrumb--current">{{ section.settings.breadcrumb_current | escape }}</span>
      </nav>
    {%- endif -%}

    <header class="ccp-header">
      {%- if section.settings.heading != blank -%}
        <h1 class="ccp-header__title">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="ccp-header__subtitle">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </header>

    <div class="ccp-cards-grid">
      <!-- Live Chat Card -->
      <div class="ccp-card" {{ section.shopify_attributes }}>
        <div class="ccp-card__icon ccp-card__icon--chat">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/>
            <circle cx="9" cy="9" r="1.5"/>
            <circle cx="15" cy="9" r="1.5"/>
          </svg>
        </div>
        <h3 class="ccp-card__title">{{ section.settings.chat_title | escape }}</h3>
        <p class="ccp-card__description">{{ section.settings.chat_description | escape }}</p>
        {%- if section.settings.chat_button_text != blank -%}
          <button
            type="button"
            id="ccp-open-chat-btn"
            class="ccp-card__button ccp-card__button--chat"
            style="background-color: {{ section.settings.button_background }}; cursor: pointer; border: none;"
            onmouseover="this.style.backgroundColor='{{ section.settings.button_background_hover }}'"
            onmouseout="this.style.backgroundColor='{{ section.settings.button_background }}'"
            onclick="ccpOpenShopifyInbox()"
          >
            {{ section.settings.chat_button_text | escape }}
          </button>
        {%- endif -%}
      </div>

      <!-- Phone Card -->
      <div class="ccp-card" {{ section.shopify_attributes }}>
        <div class="ccp-card__icon ccp-card__icon--phone">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
        </div>
        <h3 class="ccp-card__title">{{ section.settings.phone_title | escape }}</h3>
        <p class="ccp-card__description">{{ section.settings.phone_description | newline_to_br }}</p>
        <div class="ccp-card__phone-buttons">
          {%- if section.settings.phone_number_1 != blank -%}
            <a
              href="tel:{{ section.settings.phone_number_1 | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}"
              class="ccp-card__button ccp-card__button--phone"
              style="background-color: {{ section.settings.button_background }};"
              onmouseover="this.style.backgroundColor='{{ section.settings.button_background_hover }}'"
              onmouseout="this.style.backgroundColor='{{ section.settings.button_background }}'"
            >
              {{ section.settings.phone_number_1 | escape }}
            </a>
          {%- endif -%}
          {%- if section.settings.phone_number_2 != blank -%}
            <a
              href="tel:{{ section.settings.phone_number_2 | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}"
              class="ccp-card__button ccp-card__button--phone"
              style="background-color: {{ section.settings.button_background }};"
              onmouseover="this.style.backgroundColor='{{ section.settings.button_background_hover }}'"
              onmouseout="this.style.backgroundColor='{{ section.settings.button_background }}'"
            >
              {{ section.settings.phone_number_2 | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Email Card -->
      <div class="ccp-card" {{ section.shopify_attributes }}>
        <div class="ccp-card__icon ccp-card__icon--email">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
        </div>
        <h3 class="ccp-card__title">{{ section.settings.email_title | escape }}</h3>
        <p class="ccp-card__description">{{ section.settings.email_description | newline_to_br }}</p>
        <div class="ccp-card__phone-buttons">
          {%- if section.settings.email_address != blank -%}
            <a
              href="mailto:{{ section.settings.email_address }}"
              class="ccp-card__button ccp-card__button--email"
              style="background-color: {{ section.settings.button_background }};"
              onmouseover="this.style.backgroundColor='{{ section.settings.button_background_hover }}'"
              onmouseout="this.style.backgroundColor='{{ section.settings.button_background }}'"
            >
              {{ section.settings.email_address | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Address Card -->
      <div class="ccp-card" {{ section.shopify_attributes }}>
        <div class="ccp-card__icon ccp-card__icon--address">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
        </div>
        <h3 class="ccp-card__title">{{ section.settings.address_title | escape }}</h3>
        <div class="ccp-card__address">
          {{ section.settings.address_content | newline_to_br }}
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="ccp-form-section">
      <div class="ccp-form-container">
        {%- if section.settings.form_heading != blank -%}
          <h2 class="ccp-form__title">{{ section.settings.form_heading | escape }}</h2>
        {%- endif -%}

        {%- form 'contact', id: 'ContactForm', class: 'ccp-contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="ccp-form__message ccp-form__message--success" tabindex="-1" autofocus>
              <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M14.6667 4.66663L6.00001 13.3333L1.33334 8.66663L2.27334 7.72663L6.00001 11.4533L13.7267 3.72663L14.6667 4.66663Z" fill="currentColor"/>
              </svg>
              {{ 'templates.contact.form.post_success' | t }}
            </div>
          {%- elsif form.errors -%}
            <div class="ccp-form__message ccp-form__message--error">
              <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 0C3.58 0 0 3.58 0 8C0 12.42 3.58 16 8 16C12.42 16 16 12.42 16 8C16 3.58 12.42 0 8 0ZM9 12H7V10H9V12ZM9 8H7V4H9V8Z" fill="currentColor"/>
              </svg>
              {{ 'templates.contact.form.error_heading' | t }}
            </div>
          {%- endif -%}

          <div class="ccp-form__fields">
            <div class="ccp-form__field-wrapper">
              <label class="ccp-form__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
              <input
                class="ccp-form__input"
                autocomplete="name"
                type="text"
                id="ContactForm-name"
                name="contact[{{ 'templates.contact.form.name' | t }}]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                placeholder="{{ 'templates.contact.form.name' | t }}"
              >
            </div>
            <div class="ccp-form__field-wrapper">
              <label class="ccp-form__label" for="ContactForm-email">
                {{- 'templates.contact.form.email' | t }}
                <span aria-hidden="true">*</span></label
              >
              <input
                autocomplete="email"
                type="email"
                id="ContactForm-email"
                class="ccp-form__input {% if form.errors contains 'email' %}ccp-form__input--error{% endif %}"
                name="contact[email]"
                spellcheck="false"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                aria-required="true"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                {% endif %}
                placeholder="{{ 'templates.contact.form.email' | t }}"
                required
              >
            </div>
          </div>

          <div class="ccp-form__field-wrapper">
            <label class="ccp-form__label" for="ContactForm-phone">{{ 'templates.contact.form.phone' | t }}</label>
            <input
              type="tel"
              id="ContactForm-phone"
              class="ccp-form__input"
              autocomplete="tel"
              name="contact[{{ 'templates.contact.form.phone' | t }}]"
              pattern="[0-9\-]*"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
              placeholder="{{ 'templates.contact.form.phone' | t }}"
            >
          </div>

          <div class="ccp-form__field-wrapper">
            <label class="ccp-form__label" for="ContactForm-body">
              {{- 'templates.contact.form.comment' | t -}}
            </label>
            <textarea
              rows="6"
              id="ContactForm-body"
              class="ccp-form__textarea"
              name="contact[{{ 'templates.contact.form.comment' | t }}]"
              placeholder="{{ 'templates.contact.form.comment' | t }}"
            >{{- form.body -}}</textarea>
          </div>

          <div class="ccp-form__submit">
            <button type="submit" class="ccp-form__button">
              {{ section.settings.form_button_text | default: "Send Message" }}
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    --ccp-icon-color: {{ section.settings.icon_color }};
    --ccp-card-bg: {{ section.settings.card_background }};
    --ccp-card-border: {{ section.settings.card_border_color }};
    --ccp-card-border-radius: 8px;
    --ccp-card-padding: 24px;
    --ccp-cards-gap: 32px;
  }

  .ccp-section {
    background-color: #FFFFFF;
  }

  /* Breadcrumb */
  .ccp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    font-size: 14px;
  }

  .ccp-breadcrumb__link {
    color: #666666;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ccp-breadcrumb__link:hover {
    color: var(--ccp-icon-color, #E63946);
  }

  .ccp-breadcrumb__separator {
    color: #999999;
  }

  .ccp-breadcrumb--current {
    color: #999999;
  }

  /* Header */
  .ccp-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .ccp-header__title {
    font-size: 32px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .ccp-header__subtitle {
    font-size: 16px;
    color: #666666;
    margin: 0;
    line-height: 1.5;
  }

  /* Cards Grid */
  .ccp-cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--ccp-cards-gap);
  }

  @media screen and (min-width: 990px) {
    .ccp-cards-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Card */
  .ccp-card {
    background-color: var(--ccp-card-bg, #FFFFFF);
    border: 1px solid var(--ccp-card-border, #E0E0E0);
    border-radius: var(--ccp-card-border-radius, 8px);
    padding: var(--ccp-card-padding, 24px);
    text-align: center;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .ccp-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .ccp-card__icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(230, 57, 70, 0.1);
    border-radius: 50%;
  }

  .ccp-card__icon svg {
    color: var(--ccp-icon-color, #E63946);
  }

  .ccp-card__title {
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .ccp-card__description,
  .ccp-card__address {
    font-size: 14px;
    color: #555555;
    margin: 0 0 20px 0;
    line-height: 1.6;
  }

  .ccp-card__address {
    font-style: normal;
    display: block;
  }

  .ccp-card__button {
    display: inline-block;
    padding: 12px 24px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .ccp-card__button--chat,
  .ccp-card__button--phone,
  .ccp-card__button--email,
  .ccp-card__button--address {
    color: #1a1a1a;
  }

  .ccp-card__phone-buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  /* Contact Form Styles */
  .ccp-form-section {
    margin-top: 64px;
    padding-top: 64px;
    border-top: 1px solid #E0E0E0;
  }

  .ccp-form-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .ccp-form__title {
    font-size: 28px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 32px;
    text-align: center;
  }

  .ccp-contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ccp-form__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  @media screen and (max-width: 600px) {
    .ccp-form__fields {
      grid-template-columns: 1fr;
    }
  }

  .ccp-form__field-wrapper {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: left;
  }

  .ccp-form__label {
    font-size: 14px;
    font-weight: 500;
    color: #333333;
  }

  .ccp-form__input,
  .ccp-form__textarea {
    width: 100%;
    padding: 14px 18px;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    font-size: 15px;
    background: #FAFAFA;
    transition: all 0.25s ease;
    font-family: inherit;
    color: #333333;
    -webkit-appearance: none;
  }

  .ccp-form__input:focus,
  .ccp-form__textarea:focus {
    outline: none;
    border-color: var(--ccp-icon-color, #E63946);
    background: #FFFFFF;
    box-shadow: 0 0 0 4px rgba(230, 57, 70, 0.05);
  }

  .ccp-form__input::placeholder,
  .ccp-form__textarea::placeholder {
    color: #A0A0A0;
    opacity: 1;
  }

  .ccp-form__input--error {
    border-color: #E63946 !important;
    background: #FFF5F5 !important;
  }

  .ccp-form__textarea {
    resize: vertical;
    min-height: 140px;
  }

  .ccp-form__submit {
    margin-top: 15px;
    text-align: center;
    width: 100%;
  }

  .ccp-form__button {
    width: 100%;
    padding: 16px 50px;
    border: none;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #FFFFFF;
    background-color: #f97b22 !important;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(249, 123, 34, 0.2);
  }

  .ccp-form__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(249, 123, 34, 0.3);
    filter: brightness(1.1);
  }

  .ccp-form__button:active {
    transform: translateY(0);
  }

  .ccp-form__message {
    padding: 16px;
    border-radius: 4px;
    font-size: 14px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .ccp-form__message--success {
    background-color: #E8F5E9;
    color: #2E7D32;
  }

  .ccp-form__message--error {
    background-color: #FFEBEE;
    color: #C62828;
  }

  /* Responsive */
  @media screen and (max-width: 750px) {
    .ccp-cards-grid {
      grid-template-columns: 1fr;
    }

    .ccp-header__title {
      font-size: 24px;
    }

    .ccp-header__subtitle {
      font-size: 14px;
    }

    .ccp-breadcrumb {
      font-size: 12px;
    }
  }

  /* Use theme color scheme for icons in inverse backgrounds */
  .color-inverse .ccp-card__icon {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .color-inverse .ccp-card {
    border-color: rgba(255, 255, 255, 0.2);
  }

  .color-inverse .ccp-card__title {
    color: #FFFFFF;
  }

  .color-inverse .ccp-card__description {
    color: rgba(255, 255, 255, 0.7);
  }

  .color-inverse .ccp-card__button {
    color: #FFFFFF;
  }
</style>

<script>
  function ccpOpenShopifyInbox() {
    // Shopify Inbox uses a Custom Element with Shadow DOM
    // Selector: inbox-online-store-chat#ShopifyChat -> shadowRoot -> button[data-spec="toggle-button"]

    try {
      var shopifyChat = document.querySelector('inbox-online-store-chat#ShopifyChat');
      if (shopifyChat && shopifyChat.shadowRoot) {
        var toggleBtn = shopifyChat.shadowRoot.querySelector('button[data-spec="toggle-button"]');
        if (toggleBtn) {
          toggleBtn.click();
          return;
        }
      }
    } catch (e) {}

    // Fallback: try generic selectors
    var selectors = ['[data-spec="toggle-button"]', '[aria-label="Help"]', '[aria-label="Chat"]'];
    for (var i = 0; i < selectors.length; i++) {
      var btn = document.querySelector(selectors[i]);
      if (btn) {
        btn.click();
        return;
      }
    }

    // Last fallback: if chat not loaded yet, wait and retry
    var retries = 0;
    var interval = setInterval(function () {
      retries++;
      var chatEl = document.querySelector('inbox-online-store-chat#ShopifyChat');
      if (chatEl && chatEl.shadowRoot) {
        var tBtn = chatEl.shadowRoot.querySelector('button[data-spec="toggle-button"]');
        if (tBtn) {
          tBtn.click();
          clearInterval(interval);
          return;
        }
      }
      if (retries >= 10) clearInterval(interval);
    }, 500);
  }
</script>

{% schema %}
{
  "name": "Custom Contact Page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Breadcrumb"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "text",
      "id": "breadcrumb_home",
      "label": "Home text",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "breadcrumb_current",
      "label": "Current page text",
      "default": "Contact Us"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us | Gossby"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Chat with us or send us an email!"
    },
    {
      "type": "header",
      "content": "Live Chat Card"
    },
    {
      "type": "text",
      "id": "chat_title",
      "label": "Chat card title",
      "default": "Via Live Chat"
    },
    {
      "type": "textarea",
      "id": "chat_description",
      "label": "Chat card description",
      "default": "Chat with our support team 24/7"
    },
    {
      "type": "text",
      "id": "chat_button_text",
      "label": "Chat button text",
      "default": "Chat with us now"
    },
    {
      "type": "text",
      "id": "chat_button_url",
      "label": "Chat button URL",
      "default": "/"
    },
    {
      "type": "header",
      "content": "Phone Card"
    },
    {
      "type": "text",
      "id": "phone_title",
      "label": "Phone card title",
      "default": "Phone"
    },
    {
      "type": "textarea",
      "id": "phone_description",
      "label": "Phone card description",
      "default": "Available 9 AM - 5:30 PM PST, Mon - Sun"
    },
    {
      "type": "text",
      "id": "phone_number_1",
      "label": "Phone number 1",
      "default": "+1 (585) 366 8846"
    },
    {
      "type": "text",
      "id": "phone_number_2",
      "label": "Phone number 2",
      "default": "+1 (844) 976 2696"
    },
    {
      "type": "header",
      "content": "Email Card"
    },
    {
      "type": "text",
      "id": "email_title",
      "label": "Email card title",
      "default": "Email"
    },
    {
      "type": "textarea",
      "id": "email_description",
      "label": "Email card description",
      "default": "We will get back to you within 24 hours"
    },
    {
      "type": "text",
