{%- if section.settings.show_section -%}
  {%- style -%}
    .help-center-hero {
      background-color: #F97B22; /* Coral color from design */
      color: white;
      padding: 2rem 0 4rem;
      text-align: center;
      position: relative;
    }

    .help-center-hero__header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 2rem;
      font-size: 1.2rem;
      margin-bottom: 2rem;
    }

    .help-center-hero__header a {
      color: white;
      text-decoration: none;
      font-weight: 500;
    }

    .help-center-hero__title {
      font-size: 3.2rem;
      margin-bottom: 2.5rem;
      font-weight: 600;
    }

    .help-center-hero__search {
      max-width: 600px;
      margin: 0 auto;
      position: relative;
    }

    .help-center-hero__search-input {
      width: 100%;
      padding: 1.5rem 4rem 1.5rem 2rem;
      border-radius: 4px;
      border: none;
      font-size: 1.6rem;
      color: #333;
    }

    .help-center-hero__search-icon {
      position: absolute;
      right: 1.5rem;
      top: 50%;
      transform: translateY(-50%);
      color: #999;
      width: 20px;
      height: 20px;
    }

    .help-center-hero__logo img {
      max-width: 100%;
      height: auto;
      vertical-align: middle;
    }

    .help-center-hero__store-link-anchor {
      display: flex;
      align-items: center;
      gap: 1rem;
      color: white;
      text-decoration: none;
    }

    .help-center-hero__store-icon {
      width: 30px;
      height: 30px;
      object-fit: contain;
    }
  {%- endstyle -%}

  <div class="help-center-hero">
    <div class="help-center-hero__header">
      <div class="help-center-hero__logo">
        <a href="/pages/help-center">
          {%- if section.settings.logo != blank -%}
            {{
              section.settings.logo
              | image_url: width: section.settings.logo_width
              | image_tag: loading: 'eager', alt: section.settings.header_left_text
            }}
          {%- else -%}
            {{ section.settings.header_left_text }}
          {%- endif -%}
        </a>
      </div>
      <div class="help-center-hero__store-link">
        <a href="{{ routes.root_url }}" class="help-center-hero__store-link-anchor">
          {%- if section.settings.store_icon != blank -%}
            {{
              section.settings.store_icon
              | image_url: width: 60
              | image_tag: class: 'help-center-hero__store-icon', loading: 'lazy'
            }}
          {%- endif -%}
          {{ section.settings.header_right_text }}
        </a>
      </div>
    </div>

    <div class="page-width">
      <h1 class="help-center-hero__title">{{ section.settings.title }}</h1>

      <div class="help-center-hero__search">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input type="hidden" name="type" value="article,page">
          <input type="hidden" name="view" value="help-center">
          <input
            type="search"
            name="q"
            class="help-center-hero__search-input"
            placeholder="{{ section.settings.search_placeholder }}"
            aria-label="{{ section.settings.search_placeholder }}"
          >
          <div class="help-center-hero__search-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </div>
        </form>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Help Center Hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Branding (Left)"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Main Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 100,
      "unit": "px",
      "label": "Logo Width"
    },
    {
      "type": "inline_richtext",
      "id": "header_left_text",
      "label": "Header Left Text (if no logo)",
      "default": "Jollimate <span>Help Center</span>"
    },
    {
      "type": "header",
      "content": "Store Link (Right)"
    },
    {
      "type": "image_picker",
      "id": "store_icon",
      "label": "Store Icon/Logo",
      "info": "Displayed next to the store link"
    },
    {
      "type": "text",
      "id": "header_right_text",
      "label": "Header Right Text",
      "default": "Jollimate Store"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Hi, How can Jollimate help you?"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder",
      "default": "Search for answers"
    }
  ]
}
{% endschema %}
