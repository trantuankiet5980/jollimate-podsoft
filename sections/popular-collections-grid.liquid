{% schema %}
{
  "name": "Popular Collections Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "✨ EXPLORE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular Collections"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#fdf0ec"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (overrides collection image)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title (overrides collection title)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Custom Subtitle (overrides auto count)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom Link (overrides collection link)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Popular Collections Grid",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"></noscript>

<style>
  .pcg-section {
    font-family: 'Poppins', sans-serif;
  }

  .pcg-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 16px;
    width: 100%;
  }

  .pcg-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .pcg-badge {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    color: #f97b22;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
  }

  .pcg-heading {
    font-size: 30px;
    font-weight: 700;
    color: #333;
    margin: 0;
  }

  /* Swiper overrides */
  .pcg-swiper-wrapper {
    position: relative;
    padding: 0 50px;
  }

  .pcg-swiper {
    overflow: hidden;
  }

  .pcg-swiper .swiper-slide {
    height: auto;
  }

  .pcg-card {
    display: grid;
    grid-template-rows: auto auto auto;
    justify-items: stretch;
    align-items: start;
    background: transparent;
    border-radius: 0;
    padding: 0;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    min-height: 0;
    height: 100%;
  }

  .pcg-card:hover {
    transform: translateY(-4px);
  }

  .pcg-card-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    height: auto;
    object-fit: cover;
    object-position: center center;
    display: block;
    margin: 0 0 12px;
    border-radius: 14px;
    transform: none;
    transition: transform 0.3s ease;
  }

  .pcg-card:hover .pcg-card-image {
    transform: scale(1.04);
  }

  .pcg-card-title {
    font-size: 15px;
    font-weight: 600;
    color: #111;
    text-align: center;
    margin-bottom: 4px;
  }

  .pcg-card-subtitle {
    font-size: 13px;
    font-weight: 400;
    color: #888;
    text-align: center;
  }

  .pcg-card-placeholder {
    width: 100px;
    height: 100px;
    margin-bottom: 16px;
    opacity: 0.4;
  }

  /* Navigation arrows */
  .pcg-nav-prev,
  .pcg-nav-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .pcg-nav-prev:hover,
  .pcg-nav-next:hover {
    background: #f97b22;
    border-color: #f97b22;
    box-shadow: 0 4px 16px rgba(249, 123, 34, 0.35);
  }

  .pcg-nav-prev svg,
  .pcg-nav-next svg {
    width: 18px;
    height: 18px;
    stroke: #333;
    transition: stroke 0.3s ease;
  }

  .pcg-nav-prev:hover svg,
  .pcg-nav-next:hover svg {
    stroke: #fff;
  }

  .pcg-nav-prev {
    left: 0;
  }

  .pcg-nav-next {
    right: 0;
  }

  .pcg-nav-prev.swiper-button-disabled,
  .pcg-nav-next.swiper-button-disabled {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }

  .pcg-nav-prev.swiper-button-lock,
  .pcg-nav-next.swiper-button-lock {
    display: flex !important;
  }

  /* Pagination */
  .pcg-swiper-wrapper .swiper-pagination {
    position: relative;
    margin-top: 24px;
  }

  .pcg-swiper-wrapper .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    background: #ddd;
    opacity: 1;
    transition: all 0.3s ease;
  }

  .pcg-swiper-wrapper .swiper-pagination-bullet-active {
    background: #f97b22;
    width: 24px;
    border-radius: 4px;
  }

  /* Tablet */
  @media (max-width: 749px) {
    .pcg-card {
      min-height: 0;
    }
    .pcg-swiper-wrapper {
      padding: 0;
    }
    .pcg-swiper {
      overflow: visible;
    }
    .pcg-swiper .swiper-wrapper {
      padding: 0 8px;
      box-sizing: border-box;
    }
    .pcg-nav-prev,
    .pcg-nav-next {
      display: none;
    }
  }

  /* Mobile */
  @media (max-width: 749px) {
    .pcg-heading {
      font-size: 22px;
    }
    .pcg-header {
      margin-bottom: 20px;
    }
    .pcg-card {
      min-height: 0;
    }
    .pcg-card-title {
      font-size: 14px;
    }
    .pcg-card-subtitle {
      font-size: 12px;
    }
  }
</style>

<div
  class="pcg-section"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="pcg-container">
    <div class="pcg-header">
      {% if section.settings.badge_text != blank %}
        <div class="pcg-badge">{{ section.settings.badge_text }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="pcg-heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="pcg-swiper-wrapper">
      <!-- Navigation arrows (outside swiper to avoid overflow:hidden) -->
      <button class="pcg-nav-prev" id="pcg-prev-{{ section.id }}" aria-label="Previous">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="pcg-nav-next" id="pcg-next-{{ section.id }}" aria-label="Next">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
      </button>

      <div class="swiper pcg-swiper" id="pcg-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {%- assign card_collection = block.settings.collection -%}
            {%- assign card_link = block.settings.link -%}
            {%- if card_link == blank and card_collection != blank -%}
              {%- assign card_link = card_collection.url -%}
            {%- endif -%}
            {%- assign card_title = block.settings.title -%}
            {%- if card_title == blank and card_collection != blank -%}
              {%- assign card_title = card_collection.title -%}
            {%- endif -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <a href="{{ card_link | default: '#' }}" class="pcg-card">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'pcg-card-image' }}
                {% elsif card_collection != blank and card_collection.image != blank %}
                  {{ card_collection.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'pcg-card-image' }}
                {% else %}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg pcg-card-placeholder' }}
                {% endif %}
                <div class="pcg-card-title">{{ card_title | default: 'Collection Name' }}</div>
                <div class="pcg-card-subtitle">
                  {%- if block.settings.subtitle != blank -%}
                    {{ block.settings.subtitle }}
                  {%- elsif card_collection != blank -%}
                    {{ card_collection.all_products_count }}+ items
                  {%- endif -%}
                </div>
              </a>
            </div>
          {% endfor %}
        </div>

        <!-- Pagination -->
        <div class="swiper-pagination"></div>
      </div>
    </div>
  </div>
</div>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const swiperSelector = '#pcg-swiper-{{ section.id }}';
    const initSwiper = () => {
      if (typeof Swiper !== 'undefined') {
        new Swiper(swiperSelector, {
          slidesPerView: 1,
          spaceBetween: 12,
          loop: true,
          watchOverflow: true,
          grabCursor: true,
          watchSlidesProgress: true,
          pagination: {
            el: `${swiperSelector} .swiper-pagination`,
            clickable: true,
          },
          navigation: {
            nextEl: '#pcg-next-{{ section.id }}',
            prevEl: '#pcg-prev-{{ section.id }}',
          },
          breakpoints: {
            750: {
              slidesPerView: 4,
              spaceBetween: 16
            },
            990: {
              slidesPerView: 4,
              spaceBetween: 20
            },
          },
        });
      } else {
        setTimeout(initSwiper, 100);
      }
    };
    initSwiper();
  });
</script>
