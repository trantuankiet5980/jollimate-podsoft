{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-localization-form.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{{ 'custom-cart.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .cart-empty-custom {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .cart-empty-custom__oops {
    font-size: 2.8rem;
    font-weight: 700;
    color: #000;
  }
  .cart-empty-custom__inline-img {
    max-width: 550px;
    width: 100%;
    height: auto;
    object-fit: contain;
  }
  .cart-empty-custom__title {
    font-size: 2.4rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    color: #111;
  }
  .cart-empty-custom__text {
    font-size: 1.5rem;
    line-height: 1.6;
    color: #333;
    max-width: 600px;
  }
  .cart-empty-custom__btn {
    display: inline-block;
    background-color: #F97B22;
    color: #fff;
    padding: 1.2rem 3.5rem;
    border-radius: 30px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.6rem;
    transition: background-color 0.3s ease;
  }
  .cart-empty-custom__btn:hover {
    background-color: #b02625;
  }
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<cart-items class="{% if cart.item_count == 0 %} is-empty{% endif %}">
  <!-- Wrapper to ensure cart.js can always find the targets -->
  <div class="cart-empty-state-wrapper">
    <!-- Empty Cart State -->
    <div class="page-width">
      <div class="cart-empty-custom">
        <h2 class="cart-empty-custom__oops">{{ section.settings.empty_oops_text | default: 'Oops!!!' }}</h2>

        {%- if section.settings.empty_image != blank -%}
          {{
            section.settings.empty_image
            | image_url: width: 600
            | image_tag: alt: section.settings.empty_image.alt, class: 'cart-empty-custom__inline-img', loading: 'lazy'
          }}
        {%- else -%}
          <img
            src="https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-image_large.png?format=webp&v=1530129081"
            alt="Empty Cart Image placeholder"
            class="cart-empty-custom__inline-img"
            width="300"
            height="300"
            loading="lazy"
          >
        {%- endif -%}

        <h1 class="cart-empty-custom__title">{{ section.settings.empty_title | default: 'YOUR CART IS EMPTY' }}</h1>

        <p class="cart-empty-custom__text">
          {{
            section.settings.empty_subtext
            | default: "It looks like you haven't added anything to your cart. Go ahead and explore some special personalized gifts for you and your loved ones from our top categories"
          }}
        </p>

        <a
          href="{{ section.settings.empty_button_link | default: routes.all_products_collection_url }}"
          class="cart-empty-custom__btn"
        >
          {{ section.settings.empty_button_label | default: 'Keep Shopping' }}
        </a>

        {%- if shop.customer_accounts_enabled and customer == null -%}
          <div style="margin-top: 30px;">
            <p class="cart__login-paragraph">
              {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
            </p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Cart with Items -->
  <div class="custom-cart-page page-width">
    <!-- Left Column - Shopping Cart -->
    <div class="cart-left-column">
      <div class="cart-header">
        <h1 class="cart-header__title" id="cart-header-title">Shopping Cart ({{ cart.item_count }})</h1>
      </div>

      <!-- Shipping Info Section -->
      <div class="cart-shipping-info">
        <div class="cart-shipping-info__header">
          <svg
            class="cart-shipping-info__icon"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <div class="cart-shipping-info__localization">
            <div class="no-js-hidden">
              {% render 'country-localization', localPosition: 'Cart' %}
            </div>
          </div>
        </div>
        <p class="cart-shipping-info__text">
          The items in your cart are eligible for: <span class="cart-shipping-info__badge">Standard Shipping</span>
        </p>
        <p class="cart-shipping-info__note">
          More information on estimated delivery dates and pricing is available at checkout.
        </p>
      </div>

      <!-- Main Cart Form Start (Moved here to avoid nesting) -->
      <form action="{{ routes.cart_url }}" method="post" id="cart" class="cart__contents">
        <!-- Cart Items -->
        <div id="main-cart-items" data-id="{{ section.id }}">
          <div class="js-contents" id="cart-items-contents">
            {%- for item in cart.items -%}
              <div class="cart-product-card" id="CartItem-{{ item.index | plus: 1 }}">
                <!-- Action Buttons -->
                <div class="cart-product-card__actions">
                  <cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                    <button
                      type="button"
                      class="cart-product-card__btn"
                      aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                      Remove
                    </button>
                  </cart-remove-button>
                  {% comment %}
                    <button type="button" class="cart-product-card__btn">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                      </svg>
                      Edit Set
                    </button>
                  {% endcomment %}
                </div>

                <!-- Product Title -->
                <div class="cart-product-card__title">
                  {% comment %} <span class="cart-product-card__tag">Set</span> {% endcomment %}
                  <a href="{{ item.url }}">{{ item.product.title | escape }}</a>
                </div>

                <!-- Product Content -->
                <div class="cart-product-card__content">
                  <!-- Product Image -->
                  <div class="cart-product-card__image-wrapper">
                    {%- if item.image -%}
                      <img
                        src="{{ item.image | image_url: width: 300 }}"
                        class="cart-product-card__image"
                        alt="{{ item.image.alt | escape }}"
                        loading="lazy"
                        width="120"
                        height="{{ 120 | divided_by: item.image.aspect_ratio | ceil }}"
                      >
                    {%- endif -%}
                    {% comment %}<span class="cart-product-card__preview-badge">6 Preview</span>{% endcomment %}
                  </div>

                  <!-- Item Details Box -->
                  <div class="cart-product-card__details">
                    <div class="cart-product-card__item-number">
                      Item #{{ forloop.index }}: {{ item.product.type | default: 'Puzzle' }}
                    </div>
                    <div class="cart-product-card__item-info">
                      {%- if item.product.has_only_default_variant == false -%}
                        {%- for option in item.options_with_values -%}
                          {{ option.name }}: {{ option.value -}}
                          {%- unless forloop.last %} • {% endunless %}
                        {%- endfor -%}
                      {%- else -%}
                        White • 14 x 11 in (30 pieces)
                      {%- endif -%}
                    </div>
                  </div>
                </div>

                {% comment %}
                  <!-- Delivery Section -->
                  <div class="cart-product-card__delivery">
                    <span class="cart-product-card__delivery-icon">
                      <img
                        src="https://flagcdn.com/w40/{{ localization.country.iso_code | downcase }}.png"
                        width="20"
                        height="15"
                        alt="{{ localization.country.name }}"
                        class="localization-flag"
                        loading="lazy"
                      >
                    </span>
                    <span class="cart-product-card__delivery-label">Delivery</span>
                    <span class="cart-product-card__delivery-date">
                      {%- liquid
                        assign current_month = 'now' | date: '%b'
                        assign current_day = 'now' | date: '%d' | plus: 0

                        assign start_m = section.settings.delivery_start_month | default: current_month
                        if section.settings.delivery_start_month == 'none'
                          assign start_m = current_month
                        endif

                        assign start_d = section.settings.delivery_start_day
                        if start_d == 0
                          assign start_d = current_day
                        endif

                        assign end_m = section.settings.delivery_end_month | default: current_month
                        if section.settings.delivery_end_month == 'none'
                          assign end_m = current_month
                        endif

                        assign end_d = section.settings.delivery_end_day
                        if end_d == 0
                          assign end_d = current_day
                        endif

                        assign start_y = section.settings.delivery_year
                        if start_y == '0' or start_y == 0
                          assign start_y = 'now' | date: '%Y'
                        endif
                      -%}
                      Standard Shipping: Deliver by {{ start_m }}
                      {{ start_d }} - {{ end_m }}
                      {{ end_d }}, {{ start_y }}
                    </span>
                  </div>
                {% endcomment %}

                <!-- Quantity and Subtotal -->
                <div class="cart-product-card__footer">
                  <div class="cart-product-card__quantity-row">
                    <span class="cart-product-card__label">Quantity:</span>
                    <quantity-input class="cart-quantity-custom">
                      <button class="quantity__button no-js-hidden" name="minus" type="button">−</button>
                      <input
                        class="quantity__input"
                        type="number"
                        data-quantity-variant-id="{{ item.variant.id }}"
                        name="updates[]"
                        value="{{ item.quantity }}"
                        data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                        min="{{ item.variant.quantity_rule.min }}"
                        {%- assign max_qty = item.variant.quantity_rule.max | default: 9999 -%}
                        {%- if max_qty > 9999 -%}
                          {%- assign max_qty = 9999 -%}
                        {%- endif -%}
                        max="{{ max_qty }}"
                        step="{{ item.variant.quantity_rule.increment }}"
                        aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                        id="Quantity-{{ item.index | plus: 1 }}"
                        data-index="{{ item.index | plus: 1 }}"
                      >
                      <button class="quantity__button no-js-hidden" name="plus" type="button">+</button>
                    </quantity-input>
                    <span class="cart-product-card__value">{{ item.quantity }} Item</span>
                  </div>

                  <div class="cart-product-card__subtotal-row">
                    <span class="cart-product-card__subtotal-label">Set Subtotal:</span>
                    {%- if item.original_line_price != item.final_line_price -%}
                      <span class="cart-product-card__subtotal-original">{{ item.original_line_price | money }}</span>
                    {%- endif -%}
                    <span class="cart-product-card__subtotal-value">{{ item.final_line_price | money }}</span>
                  </div>
                </div>

                <!-- Loading Overlay -->
                <div class="loading-overlay hidden">
                  <div class="loading-overlay__spinner">
                    <svg
                      aria-hidden="true"
                      focusable="false"
                      class="spinner"
                      viewBox="0 0 66 66"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                    </svg>
                  </div>
                </div>

                <!-- Error Display -->
                <div class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                  <small class="cart-item__error-text"></small>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </form>
    </div>

    <!-- Right Column - Order Summary -->
    <div class="cart-right-column">
      <div class="order-summary" id="main-cart-summary" data-id="{{ section.id }}">
        <h2 class="order-summary__title">Order Summary</h2>

        {% comment %}
          <!-- Promo Code Section -->
          <div class="promo-code-section">
            <div class="promo-code-section__title">Promotional Codes & Discounts</div>
            <div class="promo-code-section__input-wrapper">
              <input type="text" class="promo-code-section__input" placeholder="Enter your Promo Code">
              <button type="button" class="promo-code-section__btn">Apply</button>
            </div>
          </div>
        {% endcomment %}

        <!-- Price Breakdown -->
        <div class="js-contents" id="cart-summary-contents">
          {%- if cart.cart_level_discount_applications.size > 0 -%}
            {%- for discount in cart.cart_level_discount_applications -%}
              <div class="order-summary__row order-summary__row--discount">
                <span class="order-summary__row-label">{{ discount.title }}: ({{ cart.item_count }} Item)</span>
                <span class="order-summary__row-value">- {{ discount.total_allocated_amount | money }}</span>
              </div>
            {%- endfor -%}
          {%- endif -%}

          {%- assign total_savings = cart.original_total_price | minus: cart.total_price -%}

          <div class="order-summary__row">
            <span class="order-summary__row-label"
              >Item Total (With Add-on): ({{ cart.item_count }}
              {% if cart.item_count > 1 %}items{% else %}item{% endif %})</span
            >
            <span class="order-summary__row-value" id="cart-item-total">{{ cart.original_total_price | money }}</span>
          </div>

          {%- if total_savings > 0 -%}
            <div class="order-summary__row order-summary__row--discount">
              <span class="order-summary__row-label"
                >Product Discount: ({{ cart.item_count }}
                {% if cart.item_count > 1 %}items{% else %}item{% endif %})</span
              >
              <span class="order-summary__row-value" id="cart-item-discount">-{{ total_savings | money }}</span>
            </div>
          {%- endif -%}

          <hr class="order-summary__divider order-summary__divider--dotted">

          <div class="order-summary__row order-summary__row--subtotal">
            <span class="order-summary__row-label">Subtotal:</span>
            <span class="order-summary__row-value" id="cart-subtotal">{{ cart.total_price | money }}</span>
          </div>

          <hr class="order-summary__divider order-summary__divider--dotted">

          <div class="order-summary__total">
            <span class="order-summary__total-label">Estimated Total:</span>
            <span class="order-summary__total-value" id="cart-total-price">
              {{- cart.total_price | money_with_currency -}}
            </span>
          </div>

          {%- if total_savings > 0 -%}
            <div class="order-summary__savings">
              <span class="order-summary__savings-label">You're saving:</span>
              <span class="order-summary__savings-value">{{ total_savings | money_with_currency }}</span>
            </div>
          {%- endif -%}

          <p class="order-summary__note">Shipping and tax will be calculated at checkout.</p>

          <!-- Checkout Button -->
          <button
            type="submit"
            name="checkout"
            class="checkout-btn"
            form="cart"
            {% if cart == empty %}
              disabled
            {% endif %}
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            Secure Checkout
          </button>

          <!-- PayPal Section -->
          {% comment %}
            <div class="paypal-section">
              <img
                src="https://www.paypalobjects.com/webstatic/mktg/Logo/pp-logo-100px.png"
                alt="PayPal"
                class="paypal-section__logo"
                width="80"
                height="20"
                loading="lazy"
              >
              <span class="paypal-section__text">Buy now, pay later.</span>
              <a href="#" class="paypal-section__link">Learn more</a>
            </div>
          {% endcomment %}
        </div>
      </div>
    </div>
  </div>

  <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
  <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">
    {{ 'accessibility.loading' | t }}
  </p>
</cart-items>

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
      "type": "header",
      "content": "Empty Cart State"
    },
    {
      "type": "text",
      "id": "empty_oops_text",
      "label": "Top Heading",
      "default": "Oops!!!"
    },
    {
      "type": "image_picker",
      "id": "empty_image",
      "label": "Custom Image",
      "info": "Upload an empty state illustration."
    },
    {
      "type": "text",
      "id": "empty_title",
      "label": "Main Title",
      "default": "YOUR CART IS EMPTY"
    },
    {
      "type": "textarea",
      "id": "empty_subtext",
      "label": "Subtext",
      "default": "It looks like you haven't added anything to your cart. Go ahead and explore some special personalized gifts for you and your loved ones from our top categories"
    },
    {
      "type": "text",
      "id": "empty_button_label",
      "label": "Button Label",
      "default": "Keep Shopping"
    },
    {
      "type": "url",
      "id": "empty_button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Delivery Info"
    },
    {
      "type": "paragraph",
      "content": "Leave Day as 0 and Month as 'Current' to default to today's date."
    },
    {
      "type": "select",
      "id": "delivery_start_month",
      "label": "Start Month",
      "options": [
        { "value": "none", "label": "Current Month" },
        { "value": "Jan", "label": "January" },
        { "value": "Feb", "label": "February" },
        { "value": "Mar", "label": "March" },
        { "value": "Apr", "label": "April" },
        { "value": "May", "label": "May" },
        { "value": "Jun", "label": "June" },
        { "value": "Jul", "label": "July" },
        { "value": "Aug", "label": "August" },
        { "value": "Sep", "label": "September" },
        { "value": "Oct", "label": "October" },
        { "value": "Nov", "label": "November" },
        { "value": "Dec", "label": "December" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "delivery_start_day",
      "min": 0,
      "max": 31,
      "step": 1,
      "label": "Start Day",
      "default": 0,
      "info": "0 targets current day"
    },
    {
      "type": "select",
      "id": "delivery_end_month",
      "label": "End Month",
      "options": [
        { "value": "none", "label": "Current Month" },
        { "value": "Jan", "label": "January" },
        { "value": "Feb", "label": "February" },
        { "value": "Mar", "label": "March" },
        { "value": "Apr", "label": "April" },
        { "value": "May", "label": "May" },
        { "value": "Jun", "label": "June" },
        { "value": "Jul", "label": "July" },
        { "value": "Aug", "label": "August" },
        { "value": "Sep", "label": "September" },
        { "value": "Oct", "label": "October" },
        { "value": "Nov", "label": "November" },
        { "value": "Dec", "label": "December" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "delivery_end_day",
      "min": 0,
      "max": 31,
      "step": 1,
      "label": "End Day",
      "default": 0,
      "info": "0 targets current day"
    },
    {
      "type": "select",
      "id": "delivery_year",
      "label": "Delivery Year",
      "options": [
        { "value": "0", "label": "Current Year" },
        { "value": "2024", "label": "2024" },
        { "value": "2025", "label": "2025" },
        { "value": "2026", "label": "2026" },
        { "value": "2027", "label": "2027" },
        { "value": "2028", "label": "2028" },
        { "value": "2029", "label": "2029" },
        { "value": "2030", "label": "2030" }
      ],
      "default": "0",
      "info": "Select 'Current Year' to default to the current year."
    }
  ]
}
{% endschema %}
