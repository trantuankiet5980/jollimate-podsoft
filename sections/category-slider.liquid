<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"></noscript>

{%- assign sid = section.id -%}
{%- assign shape_radius = '12px' -%}
{%- if section.settings.card_shape == 'circle' -%}
  {%- assign shape_radius = '50%' -%}
{%- endif -%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

  .cs-section-{{ sid }} {
    font-family: 'Poppins', sans-serif;
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .cs-container-{{ sid }} {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 15px;
    width: 100%;
    box-sizing: border-box;
  }

  .cs-header-{{ sid }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .cs-badge-{{ sid }} {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    color: #f97b22;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .cs-heading-{{ sid }} {
    font-size: 28px;
    font-weight: 700;
    color: #333;
    margin: 0;
  }

  /* Swiper wrapper */
  .cs-swiper-wrapper-{{ sid }} {
    position: relative;
    padding: 0;
  }

  .cs-swiper-{{ sid }} {
    overflow: hidden;
  }

  .cs-swiper-{{ sid }} .swiper-slide {
    height: auto;
  }

  /* Card */
  .cs-card-{{ sid }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
  }

  .cs-card-{{ sid }}:hover {
    transform: translateY(-4px);
  }

  .cs-card-image-wrap-{{ sid }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ shape_radius }};
    margin-bottom: 14px;
    background: {{ section.settings.card_bg_color }};
  }

  .cs-card-image-{{ sid }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .cs-card-{{ sid }}:hover .cs-card-image-{{ sid }} {
    transform: scale(1.05);
  }

  .cs-card-title-{{ sid }} {
    font-size: 15px;
    font-weight: 600;
    color: #111;
    text-align: center;
  }

  /* Navigation arrows */
  .cs-nav-prev-{{ sid }},
  .cs-nav-next-{{ sid }} {
    position: absolute;
    top: 42%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .cs-nav-prev-{{ sid }}:hover,
  .cs-nav-next-{{ sid }}:hover {
    background: #f97b22;
    border-color: #f97b22;
    box-shadow: 0 4px 16px rgba(249,123,34,0.35);
  }

  .cs-nav-prev-{{ sid }} svg,
  .cs-nav-next-{{ sid }} svg {
    width: 18px;
    height: 18px;
    stroke: #333;
    fill: none;
    transition: stroke 0.3s ease;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .cs-nav-prev-{{ sid }}:hover svg,
  .cs-nav-next-{{ sid }}:hover svg {
    stroke: #fff;
  }

  .cs-nav-prev-{{ sid }} { left: -15px; }
  .cs-nav-next-{{ sid }} { right: -15px; }

  .cs-nav-prev-{{ sid }}.swiper-button-disabled,
  .cs-nav-next-{{ sid }}.swiper-button-disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .cs-nav-prev-{{ sid }}.swiper-button-lock,
  .cs-nav-next-{{ sid }}.swiper-button-lock {
    display: none;
  }

  /* Pagination */
  .cs-swiper-wrapper-{{ sid }} .swiper-pagination {
    position: relative;
    margin-top: 24px;
  }

  .cs-swiper-wrapper-{{ sid }} .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    background: #ddd;
    opacity: 1;
    transition: all 0.3s ease;
  }

  .cs-swiper-wrapper-{{ sid }} .swiper-pagination-bullet-active {
    background: #f97b22;
    width: 24px;
    border-radius: 4px;
  }

  @media (max-width: 749px) {
    .cs-section-{{ sid }} { overflow: hidden; }
    .cs-heading-{{ sid }} { font-size: 28px; }
    .cs-header-{{ sid }} { margin-bottom: 20px; }
    .cs-container-{{ sid }} { padding: 0 12px; }
    .cs-swiper-wrapper-{{ sid }} { padding: 0; }
    .cs-swiper-{{ sid }} { overflow: hidden; }
    .cs-swiper-{{ sid }} .swiper-wrapper { padding: 0; box-sizing: border-box; }
    .cs-card-image-wrap-{{ sid }} { margin-bottom: 10px; }
    .cs-nav-prev-{{ sid }},
    .cs-nav-next-{{ sid }} {
      display: flex;
      width: 30px;
      height: 30px;
      top: clamp(52px, 15vw, 62px);
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    }
    .cs-nav-prev-{{ sid }} { left: -15px; }
    .cs-nav-next-{{ sid }} { right: -15px; }
    .cs-nav-prev-{{ sid }} svg,
    .cs-nav-next-{{ sid }} svg {
      width: 24px;
      height: 24px;
      stroke-width: 3;
    }
    .cs-swiper-wrapper-{{ sid }} .swiper-pagination { display: none; }
    .cs-card-title-{{ sid }} { font-size: 14px; }
  }
</style>

<div class="cs-section-{{ sid }}">
  <div class="cs-container-{{ sid }}">
    <div class="cs-header-{{ sid }}">
      {%- if section.settings.badge_text != blank -%}
        <div class="cs-badge-{{ sid }}">{{ section.settings.badge_text }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="cs-heading-{{ sid }}">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="cs-swiper-wrapper-{{ sid }}">
      <button class="cs-nav-prev-{{ sid }}" id="cs-prev-{{ sid }}" aria-label="Previous">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="cs-nav-next-{{ sid }}" id="cs-next-{{ sid }}" aria-label="Next">
        <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"></polyline></svg>
      </button>

      <div class="swiper cs-swiper-{{ sid }}" id="cs-swiper-{{ sid }}">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            {%- assign card_link = block.settings.link | default: '#' -%}
            {%- assign img_class = 'cs-card-image-' | append: sid -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <a href="{{ card_link }}" class="cs-card-{{ sid }}">
                <div class="cs-card-image-wrap-{{ sid }}">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', class: img_class }}
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: img_class }}
                  {%- endif -%}
                </div>
                {%- if block.settings.title != blank -%}
                  <div class="cs-card-title-{{ sid }}">{{ block.settings.title }}</div>
                {%- endif -%}
              </a>
            </div>
          {%- endfor -%}
        </div>
        <div class="swiper-pagination"></div>
      </div>
    </div>
  </div>
</div>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const swiperEl = document.getElementById('cs-swiper-{{ sid }}');
    if (!swiperEl) return;

    if (swiperEl.swiper) {
      swiperEl.swiper.destroy(true, true);
    }

    new Swiper(swiperEl, {
      slidesPerView: 3,
      slidesPerGroup: 1,
      spaceBetween: 8,
      loop: false,
      grabCursor: true,
      watchOverflow: true,
      pagination: {
        el: '#cs-swiper-{{ sid }} .swiper-pagination',
        clickable: true,
      },
      navigation: {
        nextEl: '#cs-next-{{ sid }}',
        prevEl: '#cs-prev-{{ sid }}',
      },
      breakpoints: {
        600: {
          slidesPerView: 3,
          slidesPerGroup: 1,
          spaceBetween: 10,
        },
        900: {
          slidesPerView: 5,
          slidesPerGroup: 1,
          spaceBetween: 16,
        },
        1100: {
          slidesPerView: 5,
          slidesPerGroup: 1,
          spaceBetween: 20,
        },
      },
    });
  });
</script>

{% schema %}
{
  "name": "Category Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "🎁 SHOP BY CATEGORY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "select",
      "id": "card_shape",
      "label": "Card Image Shape",
      "options": [
        { "value": "rounded", "label": "Rounded Square (Occasions)" },
        { "value": "circle",  "label": "Circle (Recipients/People)" }
      ],
      "default": "rounded"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#fdf0ec"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Slider (Rounded)",
      "settings": { "card_shape": "rounded", "badge_text": "🎁 SHOP BY OCCASIONS", "heading": "Shop By Occasions" },
      "blocks": [
        { "type": "item", "settings": { "title": "Birthday" } },
        { "type": "item", "settings": { "title": "Anniversary" } },
        { "type": "item", "settings": { "title": "Wedding" } },
        { "type": "item", "settings": { "title": "Mother's Day" } },
        { "type": "item", "settings": { "title": "Father's Day" } },
        { "type": "item", "settings": { "title": "Christmas" } }
      ]
    },
    {
      "name": "Category Slider (Circle)",
      "settings": { "card_shape": "circle", "badge_text": "👥 SHOP BY RECIPIENTS", "heading": "Shop By Recipients" },
      "blocks": [
        { "type": "item", "settings": { "title": "Mom/Grandma" } },
        { "type": "item", "settings": { "title": "Dad/Grandpa" } },
        { "type": "item", "settings": { "title": "Kid & Baby" } },
        { "type": "item", "settings": { "title": "Couple" } },
        { "type": "item", "settings": { "title": "Bestie" } },
        { "type": "item", "settings": { "title": "Pet Lover" } }
      ]
    }
  ]
}
{% endschema %}
