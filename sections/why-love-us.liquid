{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .why-love-us {
    background-color: {{ section.settings.background_color }};
  }

  .why-love-us__heading {
    text-align: center;
    margin-bottom: 4rem;
    font-size: 3.2rem;
    font-weight: 700;
    color: #333;
  }

  .why-love-us__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media screen and (min-width: 750px) {
    .why-love-us__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media screen and (min-width: 990px) {
    .why-love-us__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .why-love-us__item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .why-love-us__icon {
    width: 48px;
    height: 56px;
    padding-top: 4px;
    margin-bottom: 2rem;
    color: var(--top-bar-accent, {{ section.settings.accent_color }});
  }

  .why-love-us__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  .why-love-us__title {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #333;
    line-height: 1.2;
  }

  .why-love-us__description {
    font-size: 1.3rem;
    line-height: 1.5;
    color: #666;
    margin-bottom: 1rem;
    max-width: 250px;
  }

  .why-love-us__link {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--top-bar-accent, {{ section.settings.accent_color }});
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .why-love-us__link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
{%- endstyle -%}

<div class="why-love-us section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="why-love-us__heading h1">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="why-love-us__grid">
      {%- for block in section.blocks -%}
        <div class="why-love-us__item" {{ block.shopify_attributes }}>
          <div class="why-love-us__icon">
            {%- case block.settings.icon -%}
              {%- when 'gift' -%}
                <svg viewBox="0 0 24 24"><path d="M20 12v10H4V12m18-4H2v4h20V8zM12 22V8M7.5 8c-2.3 0-4.5-1.9-4.5-4s2.2-4 4.5-4 4.5 3 4.5 4-2.2 4-4.5 4zm9 0c2.3 0 4.5-1.9 4.5-4s-2.2-4-4.5-4-4.5 3-4.5 4 2.2 4 4.5 4z"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10zM9 12l2 2 4-4"/></svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- when 'heart' -%}
                <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {%- when 'message' -%}
                <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {%- endcase -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="why-love-us__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="why-love-us__description">{{ block.settings.description | escape }}</p>
          {%- endif -%}
          {%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
            <a href="{{ block.settings.link_url }}" class="why-love-us__link">{{ block.settings.link_label | escape }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Why You'll Love Us",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why You'll Love Us"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#F97B22"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "gift", "label": "Gift" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" },
            { "value": "heart", "label": "Heart" },
            { "value": "message", "label": "Message" }
          ],
          "default": "gift"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Benefit description here."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why You'll Love Us",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "gift",
            "title": "Personalized, Just For You",
            "description": "Let every gift resonate with the uniqueness of your bond.",
            "link_label": "Discover With Love"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "shield",
            "title": "Protection You Can Feel",
            "description": "With 256-bit SSL and 2048-bit RSA, your payment is in safe hands.",
            "link_label": "Shop Safely"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "star",
            "title": "You're Our Priority",
            "description": "Enjoy our 90-day unconditional refund & replacement guarantee.",
            "link_label": "Happy Purchase"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "heart",
            "title": "Here For You, Always",
            "description": "From helping hands to heartwarming chats, we're here for you.",
            "link_label": "Say Hello"
          }
        }
      ]
    }
  ]
}
{% endschema %}
