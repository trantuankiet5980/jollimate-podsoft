<div class="auth-modal" id="AuthModalLogin" aria-hidden="true" role="dialog">
  <div class="auth-modal__overlay"></div>
  <div class="auth-modal__container">
    <button type="button" class="auth-modal__close" aria-label="Close modal">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="auth-modal__content">
      <div class="auth-modal__logo">
        <a href="/" class="auth-modal__logo-link">
          {%- if section.settings.logo -%}
            <img
              src="{{ section.settings.logo | image_url: width: 150 }}"
              alt="{{ shop.name }}"
              width="150"
              height="{{ 150 | divided_by: section.settings.logo.aspect_ratio | round }}"
            >
          {%- else -%}
            <span class="auth-modal__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <h2 class="auth-modal__title">Welcome to {{ shop.name }}</h2>

      {%- form 'customer_login', class: 'auth-modal__form' -%}
        <input type="hidden" name="return_to" value="/">
        {%- if form.errors -%}
          <div class="form__message error">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="field">
          <input
            type="email"
            name="customer[email]"
            id="ModalCustomerEmail"
            autocomplete="email"
            placeholder="Email"
            required
          >
        </div>

        <div class="field">
          <input
            type="password"
            name="customer[password]"
            id="ModalCustomerPassword"
            autocomplete="current-password"
            placeholder="Password"
            required
          >
        </div>

        <div class="auth-modal__options">
          <label class="auth-modal__checkbox">
            <input type="checkbox" name="customer[accept_marketing]">
            <span>Stay signed in</span>
          </label>
          <a href="/account/login#recover" class="auth-modal__link">Forgot password?</a>
        </div>

        <button type="submit" class="button auth-modal__button">Sign In</button>

        <div class="auth-modal__divider">
          <span>OR</span>
        </div>

        <div class="auth-modal__social">
          <button type="button" class="auth-modal__social-btn auth-modal__social-btn--google">
            <svg width="18" height="18" viewBox="0 0 18 18">
              <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z"/><path fill="#FBBC05" d="M3.964 10.71c-.18-.54-.282-1.117-.282-1.71s.102-1.17.282-1.71V4.958H.957C.347 6.173 0 7.548 0 9s.348 2.827.957 4.042l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
            </svg>
            Log in with Google
          </button>
          <button type="button" class="auth-modal__social-btn auth-modal__social-btn--facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Log in with Facebook
          </button>
          <button type="button" class="auth-modal__social-btn auth-modal__social-btn--apple">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            Log in with Apple
          </button>
        </div>

        <p class="auth-modal__footer-text">
          Don't have an account? <a href="#" class="auth-modal__link" data-switch-modal="register">Sign up</a>
        </p>
      {%- endform -%}
    </div>
  </div>
</div>

<div class="auth-modal" id="AuthModalRegister" aria-hidden="true" role="dialog">
  <div class="auth-modal__overlay"></div>
  <div class="auth-modal__container">
    <button type="button" class="auth-modal__close" aria-label="Close modal">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="auth-modal__content">
      <div class="auth-modal__logo">
        <a href="/" class="auth-modal__logo-link">
          {%- if section.settings.logo -%}
            <img
              src="{{ section.settings.logo | image_url: width: 150 }}"
              alt="{{ shop.name }}"
              width="150"
              height="{{ 150 | divided_by: section.settings.logo.aspect_ratio | round }}"
            >
          {%- else -%}
            <span class="auth-modal__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <h2 class="auth-modal__title">Create an Account</h2>

      {%- form 'create_customer', class: 'auth-modal__form' -%}
        <input type="hidden" name="return_to" value="/">
        {%- if form.errors -%}
          <div class="form__message error">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="field">
          <input
            type="email"
            name="customer[email]"
            id="ModalRegisterEmail"
            autocomplete="email"
            placeholder="Email"
            required
          >
        </div>

        <div class="field">
          <input
            type="password"
            name="customer[password]"
            id="ModalRegisterPassword"
            autocomplete="new-password"
            placeholder="Password"
            required
          >
        </div>

        <div class="field">
          <input
            type="password"
            name="customer[password_confirmation]"
            id="ModalRegisterPasswordConfirmation"
            autocomplete="new-password"
            placeholder="Confirm Password"
            required
          >
        </div>

        <button type="submit" class="button auth-modal__button">Create Your Account</button>

        <p class="auth-modal__terms">
          By signing up, you agree to our <a href="/policies/terms-of-service" target="_blank">Terms</a>,
          <a href="/policies/privacy-policy" target="_blank">Data Policy</a> and
          <a href="/policies/cookies-policy" target="_blank">Cookies Policy</a>.
        </p>

        <p class="auth-modal__footer-text">
          Already have an account? <a href="#" class="auth-modal__link" data-switch-modal="login">Sign in</a>
        </p>
      {%- endform -%}
    </div>
  </div>
</div>
