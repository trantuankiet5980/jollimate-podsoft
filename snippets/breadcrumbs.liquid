{%- unless template == 'index' or template == 'cart' or template == 'list-collections' or template == '404' -%}
  {%- assign t = template | split: '.' | first -%}

  <nav class="ccp-breadcrumb breadcrumbs" aria-label="breadcrumbs">
    <a href="{{ routes.root_url }}" title="Home" class="ccp-breadcrumb__link">Home</a>

    {%- if t == 'product' -%}
      {%- if collection.url -%}
        <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
        {{ collection.title | link_to: collection.url, class: 'ccp-breadcrumb__link' }}
      {%- endif -%}

      <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
      <span class="ccp-breadcrumb--current" aria-current="page">{{ product.title }}</span>

    {%- elsif t == 'collection' and collection.handle -%}
      <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
      {%- if current_tags -%}
        {%- capture tag_url -%}{{ collection.url }}/{{ current_tags | join: "+" }}{%- endcapture -%}
        <a href="{{ tag_url }}" class="ccp-breadcrumb__link">{{ collection.title }}</a>
        <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
        <span class="ccp-breadcrumb--current" aria-current="page">{{ current_tags | join: " + " }}</span>
      {%- else -%}
        <span class="ccp-breadcrumb--current" aria-current="page">{{ collection.title }}</span>
      {%- endif -%}

    {%- elsif t == 'blog' -%}
      <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
      {%- if current_tags -%}
        <a href="{{ blog.url }}" class="ccp-breadcrumb__link">{{ blog.title }}</a>
        <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
        <span class="ccp-breadcrumb--current" aria-current="page">{{ current_tags | join: " + " }}</span>
      {%- else -%}
        <span class="ccp-breadcrumb--current" aria-current="page">{{ blog.title }}</span>
      {%- endif -%}

    {%- elsif t == 'article' -%}
      <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
      {{ blog.title | link_to: blog.url, class: 'ccp-breadcrumb__link' }}
      <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
      <span class="ccp-breadcrumb--current" aria-current="page">{{ article.title }}</span>

    {%- elsif t == 'page' -%}
      <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
      <span class="ccp-breadcrumb--current" aria-current="page">{{ page.title }}</span>

    {%- else -%}
      <span class="ccp-breadcrumb__separator" aria-hidden="true">›</span>
      <span class="ccp-breadcrumb--current" aria-current="page">{{ page_title }}</span>
    {%- endif -%}
  </nav>

  {{ 'custom-breadcrumbs.css' | asset_url | stylesheet_tag }}
{%- endunless -%}
